# ─── Base de datos ───
DATABASE_URL=postgresql://mero:mero_secret@localhost:5432/mero_db?schema=public
POSTGRES_USER=mero
POSTGRES_PASSWORD=mero_secret
POSTGRES_DB=mero_db

# ─── JWT ───
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cambiar-en-produccion-refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ───
API_PORT=3000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173

# ─── VITA (sync empleados) ───
VITA_DB_HOST=localhost
VITA_DB_PORT=5432
VITA_DB_USER=vita_readonly
VITA_DB_PASSWORD=vita_readonly_secret
VITA_DB_NAME=vita_db

# ─── Logs ───
LOG_LEVEL=info
