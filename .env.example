# ─── Base de datos ───
# Puerto 5433 porque VITA usa 5432
DATABASE_URL=postgresql://mero:mero_secret@localhost:5433/mero_db?schema=public
POSTGRES_USER=mero
POSTGRES_PASSWORD=mero_secret
POSTGRES_DB=mero_db
DB_PORT=5433

# ─── JWT ───
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cambiar-en-produccion-refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ───
API_PORT=3000
API_PREFIX=/api
CORS_ORIGIN=https://tu-dominio.com,http://localhost:4000

# ─── Web (Express + EJS) ───
WEB_PORT=4000
API_URL=http://localhost:3000/api
WEB_SESSION_COOKIE_SECURE=auto

# ─── VITA (sync empleados) ───
VITA_DB_HOST=localhost
VITA_DB_PORT=5432
VITA_DB_USER=vita_readonly
VITA_DB_PASSWORD=vita_readonly_secret
VITA_DB_NAME=vita_db

# ─── SMTP (envío de QR por correo) ───
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=agomez_nextgen@outlook.com
SMTP_PASS=tu_password_aqui

# Alias compatibles (opcional): EMAIL_* (ej. Gmail)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=tickets.simod@gmail.com
# EMAIL_PASS=tu_app_password_gmail

# ─── Proveedor de correo (smtp | graph | auto) ───
MAIL_PROVIDER=auto

# ─── Microsoft Graph (opcional, recomendado para Outlook M365) ───
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_USER=agomez_nextgen@outlook.com

# ─── Cloudflare Tunnel ───
CLOUDFLARE_TUNNEL_TOKEN=tu_token_aqui

# ─── Logs ───
LOG_LEVEL=info
