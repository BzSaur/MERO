# ─── Base de datos ───
# Puerto 5433 porque VITA usa 5432
DATABASE_URL=postgresql://mero:mero_secret@localhost:5433/mero_db?schema=public
POSTGRES_USER=mero
POSTGRES_PASSWORD=mero_secret
POSTGRES_DB=mero_db
DB_PORT=5433

# ─── JWT ───
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cambiar-en-produccion-refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ───
API_PORT=3000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:4000

# ─── Web (Express + EJS) ───
WEB_PORT=4000
API_URL=http://localhost:3000/api

# ─── VITA (sync empleados) ───
VITA_DB_HOST=localhost
VITA_DB_PORT=5432
VITA_DB_USER=vita_readonly
VITA_DB_PASSWORD=vita_readonly_secret
VITA_DB_NAME=vita_db

# ─── Logs ───
LOG_LEVEL=info
