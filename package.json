{
  "name": "mero",
  "version": "0.1.0",
  "private": true,
  "description": "MERO — Medición de Eficiencia y Rendimiento Operativo",
  "scripts": {
    "dev": "pnpm --filter api dev",
    "dev:web": "pnpm --filter @mero/web dev",
    "build": "pnpm --filter api build",
    "start": "pnpm --filter api start:prod",
    "start:web": "pnpm --filter @mero/web start",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:seed:usuarios": "pnpm --filter api prisma:seed:usuarios",
    "lint": "pnpm -r lint",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
