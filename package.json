{
  "name": "mero",
  "version": "0.1.0",
  "private": true,
  "description": "MERO — Medición de Eficiencia y Rendimiento Operativo",
  "scripts": {
    "dev": "pnpm --filter api dev",
    "dev:web": "pnpm --filter @mero/web dev",
    "build": "pnpm --filter api build",
    "start": "pnpm --filter api start:prod",
    "start:web": "pnpm --filter @mero/web start",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:seed:usuarios": "pnpm --filter api prisma:seed:usuarios",
    "lint": "pnpm -r lint",
    "mero:init": "docker network create erp_erp_network 2>/dev/null ; docker compose -f infra/docker/docker-compose.yml up -d --build",
    "mero:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "mero:down": "docker compose -f infra/docker/docker-compose.yml down",
    "mero:rebuild:api": "docker compose -f infra/docker/docker-compose.yml up -d --build --no-deps api",
    "mero:rebuild:web": "docker compose -f infra/docker/docker-compose.yml up -d --build --no-deps web",
    "mero:deploy": "git pull && docker compose -f infra/docker/docker-compose.yml up --build -d",
    "mero:tunnel:up": "docker compose -f infra/docker/docker-compose.tunnel.yml --env-file .env up -d",
    "mero:tunnel:down": "docker compose -f infra/docker/docker-compose.tunnel.yml down",
    "mero:tunnel:restart": "docker compose -f infra/docker/docker-compose.tunnel.yml restart",
    "mero:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "mero:logs:api": "docker logs -f mero-api",
    "mero:logs:web": "docker logs -f mero-web",
    "mero:studio": "dotenv -e .env -- prisma studio --schema apps/api/prisma/schema.prisma",
    "mero:seed:estandares": "docker exec -i mero-db psql -U mero mero_db < scripts/sql/seed_estandares.sql",
    "mero:backup": "./scripts/backup_pg.sh",
    "mero:restore": "./scripts/restore_pg.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
