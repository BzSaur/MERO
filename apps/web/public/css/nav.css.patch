/* =========================================
   FIX responsive nav
   (nav.css se carga DESPUÉS de layout.css,
   y estaba pisando el display:none de mobile)
   ========================================= */

@media (max-width: 768px) {
  .nav__links{
    display: none;
    position: fixed;
    top: var(--nav-h);
    left: 0; right: 0;
    flex-direction: column;
    justify-content: flex-start;
    max-width: none;
    margin: 0;
    padding: var(--gap-sm) var(--gap);
    border-radius: 0;
    background: var(--nav-bg);
    border-top: 1px solid rgba(255,255,255,.08);
    box-shadow: var(--shadow-md);
    z-index: 99;
  }
  .nav__links.open{ display: flex; }
  .nav__links::after{ content:none; } /* el pill no aplica en columna */
  .nav__links a{ width: 100%; justify-content: flex-start; }
}
