<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/icons') %>
  <%- include('../partials/nav') %>

  <div class="page">
    <div class="container">

      <div class="page-header">
        <div>
          <h1>Auditoría</h1>
          <p class="page-header__sub">Registro inmutable de cambios</p>
        </div>
        <a href="/admin" class="btn btn--ghost">
          <svg class="icon"><use href="#icon-back"/></svg>
          Volver
        </a>
      </div>

      <%- include('../partials/flash') %>

      <%# ── Filtros ── %>
      <form method="GET" action="/admin/auditoria">
        <div class="filter-bar">
          <div class="form-group">
            <label class="form-label">Desde</label>
            <input class="form-control" type="date" name="desde" value="<%= filtros.desde || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Hasta</label>
            <input class="form-control" type="date" name="hasta" value="<%= filtros.hasta || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Tabla</label>
            <select class="form-control" name="tabla">
              <option value="">Todas</option>
              <% ['mero_usuario','mero_area','mero_subtarea','mero_modelo','mero_estandar',
                  'mero_empleado','mero_asignacion','mero_captura'].forEach(t => { %>
                <option value="<%= t %>" <%= filtros.tabla === t ? 'selected' : '' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="align-self:flex-end">
            <button type="submit" class="btn btn--ghost">
              <svg class="icon"><use href="#icon-filter"/></svg>
              Filtrar
            </button>
          </div>
        </div>
      </form>

      <div class="card">
        <div class="card__header">
          <span class="card__title">Registros</span>
          <span class="badge badge--none"><%= registros.length %></span>
        </div>
        <% if (!registros.length) { %>
          <div class="empty"><p class="empty__text">Sin registros para los filtros seleccionados.</p></div>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th class="td-hide-mobile">Usuario</th>
                  <th>Tabla</th>
                  <th>Accion</th>
                  <th class="td-hide-mobile">Registro ID</th>
                  <th class="td-hide-mobile">Detalle</th>
                </tr>
              </thead>
              <tbody>
                <% registros.forEach(r => { %>
                  <tr>
                    <td class="td-mono" style="white-space:nowrap"><%= fmtDate(r.creadoEn || r.createdAt) %></td>
                    <td class="td-hide-mobile"><%= r.usuario?.nombre || r.usuarioId || '—' %></td>
                    <td class="td-mono" style="font-size:.8rem"><%= r.tabla %></td>
                    <td>
                      <span class="badge <%= r.accion === 'DELETE' ? 'badge--fail' : r.accion === 'CREATE' ? 'badge--ok' : 'badge--warn' %>">
                        <%= r.accion %>
                      </span>
                    </td>
                    <td class="td-mono td-hide-mobile"><%= r.registroId %></td>
                    <td class="td-hide-mobile">
                      <% if (r.datosDespues) { %>
                        <details>
                          <summary class="btn btn--ghost btn--sm" style="cursor:pointer; list-style:none">
                            Ver datos
                          </summary>
                          <pre style="font-size:.75rem; color:var(--ink-dim); margin-top:.5rem; overflow:auto; max-width:400px"><%= JSON.stringify(r.datosDespues, null, 2) %></pre>
                        </details>
                      <% } else { %>
                        <span style="color:var(--ink-muted)">—</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</body>
</html>
