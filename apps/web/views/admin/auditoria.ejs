<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--auditoria">
          <div class="container">

            <!-- ✅ Volver arriba derecha -->
            <div class="page-header page-header--auditoria">
              <div>
                <h1>Auditoría</h1>
                <h2><p class="page-header__sub">Registro inmutable de cambios</p></h2>
              </div>

              <a href="/admin" class="btn btn--back">
                <svg class="icon"><use href="#icon-back"/></svg>
                Volver
              </a>
            </div>

            <%- include('../partials/flash') %>

            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Filtros</span></h3>
              </div>

              <%
                const today = new Date().toISOString().slice(0, 10);
              %>

              <form method="GET" action="/admin/auditoria">
                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg);">
                  <div class="form-group users-controls__field">
                    <label class="form-label">Desde</label>
                    <input
                      class="form-control"
                      type="date"
                      name="desde"
                      value="<%= filtros.desde || '' %>"
                      max="<%= today %>"
                    >
                  </div>

                  <div class="form-group users-controls__field">
                    <label class="form-label">Hasta</label>
                    <input
                      class="form-control"
                      type="date"
                      name="hasta"
                      value="<%= filtros.hasta || '' %>"
                      max="<%= today %>"
                    >
                  </div>

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label">Tabla</label>
                    <select class="form-control" name="tabla">
                      <option value="">Todas</option>
                      <% ['mero_usuario','mero_area','mero_subtarea','mero_modelo','mero_estandar',
                          'mero_empleado','mero_asignacion','mero_captura'].forEach(t => { %>
                        <option value="<%= t %>" <%= filtros.tabla === t ? 'selected' : '' %>><%= t %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="form-group users-controls__actions">
                    <button type="submit" class="btn btn--edit">
                      <svg class="icon"><use href="#icon-filter"/></svg>
                      Filtrar
                    </button>

                    <!-- ✅ Limpiar (quita querystring / filtros) -->
                    <a href="/admin/auditoria" class="btn btn--ghost">
                      Limpiar
                    </a>
                  </div>
                </div>
              </form>
            </div>

            <div class="card card--asignar card--asignar-act">
              <div class="card__header">
                <h3><span class="card__title">Registros</span></h3>
                <span class="badge badge--ok"><%= registros.length %></span>
              </div>

              <% if (!registros.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin registros para los filtros seleccionados.</p>
                </div>
              <% } else { %>

                <div class="table-wrap table-wrap--asignar table-wrap--blue">
                  <!-- ✅ sin table--stack, para que en móvil sea igual que desktop (con scroll) -->
                  <table class="table table--blue table--auditoria">
                    <thead>
                      <tr>
                        <th>Fecha</th>
                        <th>Usuario</th>
                        <th>Tabla</th>
                        <th>Acción</th>
                        <th>Registro ID</th>
                        <th>Detalle</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% registros.forEach(r => { %>
                        <tr>
                          <td class="td-mono" style="white-space:nowrap">
                            <%= fmtDate(r.creadoEn || r.createdAt) %>
                          </td>

                          <td><%= r.usuario?.nombre || r.usuarioId || '—' %></td>

                          <td class="td-mono"><%= r.tabla %></td>

                          <td>
                            <span class="badge <%= r.accion === 'DELETE' ? 'badge--fail' : r.accion === 'CREATE' ? 'badge--ok' : 'badge--warn' %>">
                              <%= r.accion %>
                            </span>
                          </td>

                          <td class="td-mono"><%= r.registroId %></td>

                          <td>
                            <% if (r.datosDespues) { %>
                              <details>
                                <summary class="btn btn--edit btn--sm" style="cursor:pointer; list-style:none; display:inline-flex">
                                  Ver datos
                                </summary>

                                <pre class="td-mono pre-json"><%= JSON.stringify(r.datosDespues, null, 2) %></pre>
                              </details>
                            <% } else { %>
                              <span style="color:rgba(15,23,42,.55)">—</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>

              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
</body>
</html>