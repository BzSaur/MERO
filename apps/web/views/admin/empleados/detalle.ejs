<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--usuarios page--empleado-detalle">
          <div class="container">

            <%
              const nombreCompleto = `${empleado.nombre || ''} ${empleado.apellidos || ''}`.trim();
              const partesNombre = nombreCompleto.split(' ').filter(Boolean);
              const iniciales = partesNombre.length >= 2
                ? `${partesNombre[0][0] || ''}${partesNombre[1][0] || ''}`.toUpperCase()
                : (nombreCompleto.slice(0, 2) || 'EM').toUpperCase();

              let anos = 0;
              let meses = 0;

              if (empleado.vita?.fechaIngreso) {
                const ingreso = new Date(empleado.vita.fechaIngreso);
                const hoy = new Date();

                anos = hoy.getFullYear() - ingreso.getFullYear();
                meses = hoy.getMonth() - ingreso.getMonth();

                if (meses < 0) {
                  anos--;
                  meses += 12;
                }

                if (hoy.getDate() < ingreso.getDate()) {
                  meses--;
                  if (meses < 0) {
                    anos--;
                    meses += 12;
                  }
                }
              }
            %>

            <div class="employee-hero">
              <div class="employee-hero__main">
                <div class="employee-hero__avatar">
                  <span><%= iniciales %></span>
                </div>

                <div class="employee-hero__copy">
                  <div class="employee-hero__topline">
                    <span class="employee-hero__eyebrow">Perfil de empleado</span>

                    <% if (empleado.activo) { %>
                      <span class="badge badge--ok">Activo</span>
                    <% } else { %>
                      <span class="badge badge--fail">Inactivo</span>
                    <% } %>
                  </div>

                  <h1 class="employee-hero__title"><%= nombreCompleto %></h1>

                  <div class="employee-hero__meta">
                    <span class="employee-chip">
                      <svg class="icon"><use href="#icon-person"/></svg>
                      ID VITA: <strong><%= empleado.idVita %></strong>
                    </span>

                    <% if (empleado.vita?.area) { %>
                      <span class="employee-chip">
                        <svg class="icon"><use href="#icon-briefcase"/></svg>
                        Área: <strong><%= empleado.vita.area %></strong>
                      </span>
                    <% } %>

                    <% if (empleado.vita?.puesto) { %>
                      <span class="employee-chip">
                        <svg class="icon"><use href="#icon-logo"/></svg>
                        Puesto: <strong><%= empleado.vita.puesto %></strong>
                      </span>
                    <% } %>
                  </div>
                </div>
              </div>

              <div class="employee-hero__actions">
                <a href="/admin/empleados" class="btn btn--ghost btn--back-users employee-hero__back">
                  <svg class="icon"><use href="#icon-back"/></svg>
                  Regresar
                </a>
              </div>
            </div>

            <%- include('../../partials/flash') %>

            <div class="empleado-detail-grid">

              <section class="card employee-card employee-card--info">
                <div class="card__header employee-card__header">
                  <span class="card__title">
                    <svg class="icon"><use href="#icon-person"/></svg>
                    Datos del empleado
                  </span>
                </div>

                <div class="card__body employee-card__body">
                  <div class="employee-info-list">
                    <div class="employee-info-item">
                      <span class="employee-info-item__label">Nombre completo</span>
                      <strong class="employee-info-item__value"><%= nombreCompleto %></strong>
                    </div>

                    <div class="employee-info-item">
                      <span class="employee-info-item__label">ID VITA</span>
                      <span class="employee-info-item__value td-mono"><%= empleado.idVita %></span>
                    </div>

                    <% if (empleado.vita?.email) { %>
                      <div class="employee-info-item employee-info-item--full">
                        <span class="employee-info-item__label">Email corporativo</span>
                        <span class="employee-info-item__value"><%= empleado.vita.email %></span>
                      </div>
                    <% } %>
                  </div>
                </div>
              </section>

              <section class="card employee-card employee-card--info">
                <div class="card__header employee-card__header">
                  <span class="card__title">
                    <svg class="icon"><use href="#icon-briefcase"/></svg>
                    Información laboral
                  </span>
                </div>

                <div class="card__body employee-card__body">
                  <div class="employee-info-list">
                    <div class="employee-info-item">
                      <span class="employee-info-item__label">Puesto</span>
                      <strong class="employee-info-item__value"><%= empleado.vita?.puesto || '—' %></strong>
                    </div>

                    <div class="employee-info-item">
                      <span class="employee-info-item__label">Área</span>
                      <strong class="employee-info-item__value"><%= empleado.vita?.area || '—' %></strong>
                    </div>

                    <div class="employee-info-item">
                      <span class="employee-info-item__label">Fecha de ingreso</span>
                      <strong class="employee-info-item__value">
                        <%= empleado.vita?.fechaIngreso
                          ? new Date(empleado.vita.fechaIngreso).toLocaleDateString('es-MX')
                          : '—' %>
                      </strong>
                    </div>

                    <div class="employee-info-item">
                      <span class="employee-info-item__label">Antigüedad</span>
                      <strong class="employee-info-item__value">
                        <%= empleado.vita?.fechaIngreso
                          ? `${anos} año${anos !== 1 ? 's' : ''}, ${meses} mes${meses !== 1 ? 'es' : ''}`
                          : '—' %>
                      </strong>
                    </div>
                  </div>
                </div>
              </section>

              <section class="card employee-card employee-card--status">
                <div class="card__header employee-card__header">
                  <span class="card__title">
                    <svg class="icon"><use href="#icon-logo"/></svg>
                    Estado en MERO
                  </span>
                </div>

                <div class="card__body employee-card__body">
                  <div class="employee-status">
                    <div class="employee-status__block">
                      <span class="employee-status__label">Estado</span>
                      <div class="employee-status__value">
                        <% if (empleado.activo) { %>
                          <span class="badge badge--ok">Activo</span>
                        <% } else { %>
                          <span class="badge badge--fail">Inactivo</span>
                        <% } %>
                      </div>
                    </div>

                    <div class="employee-status__block">
                      <span class="employee-status__label">Registrado en MERO</span>
                      <div class="employee-status__value">
                        <%= new Date(empleado.createdAt).toLocaleDateString('es-MX') %>
                      </div>
                    </div>

                    <div class="employee-status__block">
                      <span class="employee-status__label">Última actualización</span>
                      <div class="employee-status__value">
                        <%= new Date(empleado.updatedAt).toLocaleDateString('es-MX') %>
                      </div>
                    </div>
                  </div>
                </div>
              </section>

            </div>

            <section class="card card--asignar-act empleado-detail-history">
              <div class="card__header employee-card__header employee-card__header--history">
                <span class="card__title">
                  <svg class="icon"><use href="#icon-clock"/></svg>
                  Asignaciones recientes
                </span>

                <% if (empleado.asignaciones?.length) { %>
                  <span class="badge badge--none"><%= empleado.asignaciones.length %> registro<%= empleado.asignaciones.length !== 1 ? 's' : '' %></span>
                <% } %>
              </div>

              <% if (!empleado.asignaciones || !empleado.asignaciones.length) { %>
                <div class="empty empty--employee">
                  <p class="empty__text">Este empleado no tiene asignaciones registradas.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--clean employee-table-wrap">
                  <table class="table table--clean">
                    <thead>
                      <tr>
                        <th>Fecha</th>
                        <th>Área</th>
                        <th class="td-hide-mobile">Subtarea</th>
                        <th class="td-hide-mobile">Modelo</th>
                        <th class="td-hide-mobile">Hora inicio</th>
                        <th class="td-hide-mobile">Hora fin</th>
                        <th>Estado</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% empleado.asignaciones.forEach(a => { %>
                        <tr>
                          <td class="td-mono">
                            <%= a.fecha ? new Date(a.fecha).toLocaleDateString('es-MX', { timeZone: 'America/Mexico_City' }) : '—' %>
                          </td>

                          <td><%= a.areaId || '—' %></td>
                          <td class="td-hide-mobile"><%= a.subtareaId || '—' %></td>
                          <td class="td-hide-mobile"><%= a.modeloId || '—' %></td>
                          <td class="td-hide-mobile td-mono"><%= a.horaInicio || '—' %></td>
                          <td class="td-hide-mobile td-mono"><%= a.horaFin || '—' %></td>

                          <td>
                            <% if (a.activa) { %>
                              <span class="badge badge--ok">Activa</span>
                            <% } else { %>
                              <span class="badge badge--none">Finalizada</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </section>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
</body>
</html>