<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--empleados-agenda">
          <div class="container">

            <!-- ── Header ── -->
            <div class="emp-page-header">
              <div class="emp-page-header__left">
                <h1 class="emp-page-header__title">
                  Empleados
                  <span class="emp-page-header__count" id="headerCount"><%= empleados.length %> activos</span>
                </h1>
                <p class="emp-page-header__summary" id="headerSummary">Cargando resumen…</p>
              </div>
              <form action="/admin/empleados/sync" method="POST" class="emp-page-header__sync">
                <button type="submit" class="btn btn--ghost btn--sm" title="Sincronizar empleados con VITA">
                  <svg class="icon"><use href="#icon-refresh"/></svg>
                </button>
              </form>
            </div>

            <%- include('../../partials/flash') %>

            <!-- ── Controles de búsqueda y filtros ── -->
            <div class="emp-controls card">
              <div class="emp-controls__search">
                <svg class="icon emp-controls__search-icon"><use href="#icon-search"/></svg>
                <input
                  type="search"
                  id="empSearch"
                  class="emp-controls__search-input"
                  placeholder="Buscar por nombre o área…"
                  autocomplete="off"
                />
                <button type="button" class="emp-controls__search-clear" id="searchClear" hidden title="Limpiar búsqueda">
                  <svg class="icon"><use href="#icon-x-circle"/></svg>
                </button>
              </div>
              <div class="emp-controls__filters">
                <div class="emp-filter-chips" id="areaChips">
                  <!-- generado por JS -->
                </div>
                <div class="emp-quick-filters">
                  <button type="button" class="chip chip--quick" data-qf="sin-correo" id="qfSinCorreo">
                    <svg class="icon"><use href="#icon-mail-off"/></svg>
                    Sin correo
                  </button>
                  <button type="button" class="chip chip--quick" data-qf="sin-qr" id="qfSinQr">
                    <svg class="icon"><use href="#icon-qr"/></svg>
                    Sin QR
                  </button>
                </div>
              </div>
            </div>

            <!-- ── Barra de selección ── -->
            <div class="emp-selection-bar" id="selectionBar">
              <label class="emp-selection-bar__all">
                <input type="checkbox" id="selectAll" class="emp-cb">
                <span>Seleccionar todos</span>
              </label>
              <span class="emp-selection-bar__count" id="selectedCount">0 seleccionados</span>
            </div>

            <!-- ── Lista agenda ── -->
            <div id="agendaContainer">
              <!-- Generado por empleados.js -->
            </div>

            <!-- ── Empty state ── -->
            <div class="emp-empty" id="empEmpty" hidden>
              <svg class="icon emp-empty__icon"><use href="#icon-filter"/></svg>
              <p>No hay empleados que coincidan con los filtros aplicados.</p>
            </div>

          </div><!-- /container -->
        </div><!-- /page -->
      </main>
    </div>
  </div>

  <!-- ── Barra flotante de acciones ── -->
  <div class="emp-action-bar" id="actionBar" hidden>
    <span class="emp-action-bar__info" id="actionBarInfo">0 empleados seleccionados</span>
    <button type="button" class="btn btn--qr-sheet" id="qrSheetBtn">
      <svg class="icon"><use href="#icon-print"/></svg>
      Descargar QR (6)
    </button>
    <button type="button" class="btn btn--send" id="sendQrBtn">
      <svg class="icon"><use href="#icon-send"/></svg>
      Enviar QR por correo
    </button>
  </div>

  <!-- ── Modal de confirmación de envío ── -->
  <div class="emp-modal-backdrop" id="sendModalBackdrop" hidden>
    <div class="emp-modal" id="sendModal" role="dialog" aria-modal="true" aria-labelledby="sendModalTitle">

      <!-- Vista: confirmación -->
      <div id="sendViewConfirm">
        <div class="emp-modal__header">
          <h2 class="emp-modal__title" id="sendModalTitle">Enviar QR</h2>
          <button class="emp-modal__close" id="sendModalClose" aria-label="Cerrar">
            <svg class="icon"><use href="#icon-x"/></svg>
          </button>
        </div>
        <div class="emp-modal__body">
          <p id="sendModalDesc"></p>
          <div class="emp-modal__breakdown" id="sendModalBreakdown"></div>
        </div>
        <div class="emp-modal__footer">
          <button class="btn btn--ghost" id="cancelSendBtn">Cancelar</button>
          <button class="btn btn--send" id="confirmSendBtn">
            <svg class="icon"><use href="#icon-send"/></svg>
            Enviar
          </button>
        </div>
      </div>

      <!-- Vista: enviando -->
      <div id="sendViewProgress" hidden>
        <div class="emp-modal__header">
          <h2 class="emp-modal__title">Enviando…</h2>
        </div>
        <div class="emp-modal__body">
          <div class="emp-progress">
            <div class="emp-progress__bar">
              <div class="emp-progress__fill" id="progressFill" style="width:0%"></div>
            </div>
            <p class="emp-progress__label" id="progressLabel">Preparando envío…</p>
          </div>
        </div>
      </div>

      <!-- Vista: resultados -->
      <div id="sendViewResults" hidden>
        <div class="emp-modal__header">
          <h2 class="emp-modal__title">Resultados del envío</h2>
          <button class="emp-modal__close" id="resultsModalClose" aria-label="Cerrar">
            <svg class="icon"><use href="#icon-x"/></svg>
          </button>
        </div>
        <div class="emp-modal__body">
          <div class="emp-results-summary" id="resultsSummary"></div>
          <div class="emp-results-detail" id="resultsDetail" hidden>
            <table class="table table--clean emp-results-table">
              <thead>
                <tr>
                  <th>Empleado</th>
                  <th>Correo</th>
                  <th>Estado</th>
                </tr>
              </thead>
              <tbody id="resultsTableBody"></tbody>
            </table>
          </div>
          <button class="btn btn--ghost btn--sm emp-results-toggle" id="resultsToggleBtn">Ver detalle</button>
        </div>
        <div class="emp-modal__footer">
          <button class="btn btn--create" id="closeResultsBtn">Cerrar</button>
        </div>
      </div>

    </div>
  </div>

  <div id="sidebarOverlay"></div>

  <!-- Datos de empleados para el JS -->
  <script>
    window.EMPLEADOS_DATA = <%- JSON.stringify(empleados) %>;
  </script>

  <script src="/js/main.js"></script>
  <script src="/js/empleados.js?v=20260417c"></script>
</body>
</html>
