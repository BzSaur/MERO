<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>
<body>
  <%- include('../../partials/icons') %>
  <%- include('../../partials/nav') %>

  <div class="page page--asignar page--usuarios">
    <div class="container">

      <div class="page-header">
        <div>
          <h1><%= usuario ? 'Editar usuario' : 'Nuevo usuario' %></h1>
        </div>
        <a href="/admin/usuarios" class="btn btn--ghost">
          <svg class="icon"><use href="#icon-back"/></svg>
          Volver
        </a>
      </div>

      <%- include('../../partials/flash') %>

      <div style="max-width: 720px">
        <div class="card card--asignar">
          <div class="card__header">
            <span class="card__title"><%= usuario ? 'Editar usuario' : 'Nuevo usuario' %></span>
            <span class="badge badge--ok"><%= usuario ? 'EDITAR' : 'NUEVO' %></span>
          </div>

          <!-- Form principal -->
          <form
            id="userForm"
            method="POST"
            action="<%= usuario ? `/admin/usuarios/${usuario.id}` : '/admin/usuarios' %>"
          >
            <div class="form-group">
              <label class="form-label" for="nombre">Nombre completo</label>
              <input
                class="form-control"
                type="text"
                id="nombre"
                name="nombre"
                value="<%= usuario?.nombre || '' %>"
                required
                placeholder="Juan García"
              >
            </div>

            <div class="form-group">
              <label class="form-label" for="email">Correo</label>
              <input
                class="form-control"
                type="email"
                id="email"
                name="email"
                value="<%= usuario?.email || '' %>"
                required
                placeholder="usuario@empresa.com"
              >
            </div>

            <% if (!usuario) { %>
              <div class="form-group">
                <label class="form-label" for="password">Contraseña</label>
                <input
                  class="form-control"
                  type="password"
                  id="password"
                  name="password"
                  required
                  placeholder="••••••••"
                  minlength="8"
                >
              </div>
            <% } %>

            <div class="form-group">
              <label class="form-label" for="rol">Rol</label>
              <select class="form-control" id="rol" name="rol" required>
                <% ['ADMIN', 'ENCARGADO', 'CONSULTOR'].forEach(r => { %>
                  <option value="<%= r %>" <%= usuario?.rol === r ? 'selected' : '' %>><%= r %></option>
                <% }) %>
              </select>
            </div>
          </form>

          <!-- Form eliminar (solo editar) -->
          <% if (usuario) { %>
            <form
              id="deleteUserForm"
              method="POST"
              action="/admin/usuarios/<%= usuario.id %>/eliminar"
              data-confirm-delete="1"
              data-user-name="<%= usuario?.nombre || 'este usuario' %>"
            ></form>
          <% } %>

          <!-- Botonera -->
          <div style="display:flex; gap:var(--gap-sm); align-items:center; flex-wrap:wrap">
            <button type="submit" class="btn btn--primary" form="userForm">
              <svg class="icon"><use href="#icon-check"/></svg>
              <%= usuario ? 'Guardar cambios' : 'Crear usuario' %>
            </button>

            <a href="/admin/usuarios" class="btn btn--ghost">Cancelar</a>

            <% if (usuario) { %>
              <button type="submit" class="btn btn--danger" form="deleteUserForm" style="margin-left:auto">
                Eliminar
              </button>
            <% } %>
          </div>

        </div>
      </div>

    </div>
  </div>

  <%- include('../../partials/appModal') %>
  <script src="/js/alerts.js" defer></script>
</body>
</html>