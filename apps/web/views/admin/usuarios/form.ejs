<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--usuarios page--usuarios-form">
          <div class="container">

            <div class="page-header page-header--usuarios-form">
              <a href="/admin/usuarios" class="btn btn--back btn--back-users">
              <svg class="icon"><use href="#icon-back"/></svg>
              Volver
            </a>
            </div>

            <div class="js-flash-swal-source" hidden aria-hidden="true">
              <%- include('../../partials/flash') %>
            </div>

            <section class="user-form-shell">
              <div class="user-form-brand">
                <div class="user-form-brand__logo">
                  <!-- Reemplaza la ruta por la de tu logo -->
                  <img src="/img/logo_ram.png" alt="Logo del sistema">
                </div>

                <h1 class="user-form-brand__title">
                  <%= usuario ? 'Editar usuario' : 'Nuevo usuario' %>
                </h1>

                <p class="user-form-brand__subtitle">
                  <%= usuario ? 'Actualiza la información del usuario.' : 'Completa los datos para registrar un nuevo usuario.' %>
                </p>
              </div>

              <div class="user-form-card card card--asignar">
                <div class="card__header card__header--usuarios-form">
                  <div class="card__header-left">
                    <span class="card__title">
                      <%= usuario ? 'Editar usuario' : 'Nuevo usuario' %>
                    </span>
                    <span class="badge badge--ok">
                      <%= usuario ? 'EDITAR' : 'NUEVO' %>
                    </span>
                  </div>
                </div>

                <form
                  id="userForm"
                  class="user-form"
                  method="POST"
                  action="<%= usuario ? `/admin/usuarios/${usuario.id}` : '/admin/usuarios' %>"
                  data-confirm-submit="1"
                  data-confirm-title="<%= usuario ? '¿Guardar cambios?' : '¿Crear usuario?' %>"
                  data-confirm-text="<%= usuario ? 'Se actualizará la información del usuario.' : 'Se registrará el nuevo usuario en el sistema.' %>"
                  data-confirm-button="<%= usuario ? 'Sí, guardar' : 'Sí, crear' %>"
                >
                  <div class="user-form__grid">
                    <div class="form-group">
                      <label class="form-label" for="nombre">Nombre completo</label>
                      <input
                        class="form-control"
                        type="text"
                        id="nombre"
                        name="nombre"
                        value="<%= usuario?.nombre || '' %>"
                        required
                        placeholder="Juan García"
                      >
                    </div>

                    <div class="form-group">
                      <label class="form-label" for="email">Correo</label>
                      <input
                        class="form-control"
                        type="email"
                        id="email"
                        name="email"
                        value="<%= usuario?.email || '' %>"
                        required
                        placeholder="usuario@empresa.com"
                      >
                    </div>

                    <% if (!usuario) { %>
                      <div class="form-group">
                        <label class="form-label" for="password">Contraseña</label>
                        <input
                          class="form-control"
                          type="password"
                          id="password"
                          name="password"
                          required
                          placeholder="••••••••"
                          minlength="8"
                        >
                      </div>
                    <% } else { %>
                      <div class="form-group">
                        <label class="form-label" for="password">Nueva contraseña <span style="font-weight:400;opacity:.6">(dejar vacío para no cambiar)</span></label>
                        <input
                          class="form-control"
                          type="password"
                          id="password"
                          name="password"
                          placeholder="••••••••"
                          minlength="8"
                        >
                      </div>
                    <% } %>

                    <div class="form-group">
                      <label class="form-label" for="rol">Rol</label>
                      <select class="form-control" id="rol" name="rol" required>
                        <% ['ADMIN', 'ENCARGADO', 'CONSULTOR'].forEach(r => { %>
                          <option value="<%= r %>" <%= usuario?.rol === r ? 'selected' : '' %>>
                            <%= r %>
                          </option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="form-group js-area-group" data-role-only="ENCARGADO" <%= usuario?.rol === 'ENCARGADO' ? '' : 'hidden' %>>
                      <label class="form-label" for="areaId">Área asignada</label>
                      <select class="form-control" id="areaId" name="areaId">
                        <option value="">— Selecciona un área —</option>
                        <% (typeof areas !== 'undefined' ? areas : []).forEach(a => { %>
                          <option value="<%= a.id %>" <%= usuario?.areaId === a.id ? 'selected' : '' %>>
                            <%= a.nombre %>
                          </option>
                        <% }) %>
                      </select>
                    </div>
                  </div>

                  <% if (usuario && typeof subtareas !== 'undefined' && subtareas.length) { %>
                    <section
                      class="user-form__actividades js-actividades"
                      data-role-only="ENCARGADO"
                      <%= usuario.rol === 'ENCARGADO' ? '' : 'hidden' %>
                    >
                      <header class="user-form__actividades-header">
                        <h2 class="user-form__actividades-title">Actividades del encargado</h2>
                        <p class="user-form__actividades-subtitle">
                          Marca o desmarca subtareas para reasignarlas. Al desmarcar una subtarea del área actual,
                          elige a qué otra área moverla.
                        </p>
                      </header>

                      <% const areasList = (typeof areas !== 'undefined' ? areas : []); %>
                      <% const areasById = {}; areasList.forEach(a => { areasById[a.id] = a; }); %>
                      <%
                        const groups = {};
                        subtareas.forEach(st => {
                          const k = st.areaId;
                          if (!groups[k]) groups[k] = [];
                          groups[k].push(st);
                        });
                        const currentAreaId = usuario.areaId || null;
                      %>

                      <div class="user-form__actividades-current" data-current-area="<%= currentAreaId || '' %>">
                        <h3 class="user-form__actividades-group-title">
                          Subtareas del área actual
                          <% if (currentAreaId && areasById[currentAreaId]) { %>
                            — <%= areasById[currentAreaId].nombre %>
                          <% } %>
                        </h3>

                        <% if (currentAreaId && groups[currentAreaId] && groups[currentAreaId].length) { %>
                          <ul class="user-form__actividades-list">
                            <% groups[currentAreaId].forEach(st => { %>
                              <li class="user-form__actividad js-actividad" data-subtarea-id="<%= st.id %>" data-original-area="<%= st.areaId %>">
                                <label class="user-form__actividad-label">
                                  <input
                                    type="checkbox"
                                    class="js-actividad-check"
                                    data-subtarea-id="<%= st.id %>"
                                    data-original-area="<%= st.areaId %>"
                                    checked
                                  >
                                  <span><%= st.nombre %></span>
                                </label>

                                <div class="user-form__actividad-move" hidden>
                                  <label>
                                    Mover a:
                                    <select class="form-control form-control--sm js-actividad-destino">
                                      <option value="">— elige área —</option>
                                      <% areasList.forEach(a => { %>
                                        <% if (a.id !== currentAreaId) { %>
                                          <option value="<%= a.id %>"><%= a.nombre %></option>
                                        <% } %>
                                      <% }) %>
                                    </select>
                                  </label>
                                </div>
                              </li>
                            <% }) %>
                          </ul>
                        <% } else { %>
                          <p class="user-form__actividades-empty">
                            Esta área aún no tiene subtareas asignadas. Puedes jalar subtareas desde abajo o crearlas en
                            <a href="/admin/catalogos/subtareas">Catálogo de Subtareas</a>.
                          </p>
                        <% } %>
                      </div>

                      <details class="user-form__actividades-others">
                        <summary>Ver subtareas de otras áreas para agregar al encargado</summary>

                        <% Object.keys(groups).forEach(k => {
                             const aid = Number(k);
                             if (currentAreaId && aid === currentAreaId) return;
                             const area = areasById[aid];
                             if (!area) return;
                        %>
                          <div class="user-form__actividades-group">
                            <h4 class="user-form__actividades-group-title"><%= area.nombre %></h4>
                            <ul class="user-form__actividades-list">
                              <% groups[k].forEach(st => { %>
                                <li class="user-form__actividad js-actividad" data-subtarea-id="<%= st.id %>" data-original-area="<%= st.areaId %>">
                                  <label class="user-form__actividad-label">
                                    <input
                                      type="checkbox"
                                      class="js-actividad-check"
                                      data-subtarea-id="<%= st.id %>"
                                      data-original-area="<%= st.areaId %>"
                                    >
                                    <span><%= st.nombre %></span>
                                    <small class="user-form__actividad-hint">(actualmente en: <%= area.nombre %>)</small>
                                  </label>
                                </li>
                              <% }) %>
                            </ul>
                          </div>
                        <% }) %>
                      </details>
                    </section>
                  <% } %>

                  <input type="hidden" name="cambiosSubtareas" id="cambiosSubtareas" form="userForm" value="">
                </form>

                <% if (usuario) { %>
                  <form
                    id="deleteUserForm"
                    method="POST"
                    action="/admin/usuarios/<%= usuario.id %>/eliminar"
                    data-confirm-delete="1"
                    data-kind="usuario"
                    data-nombre="<%= usuario?.nombre || 'este usuario' %>"
                    data-descripcion="<%= usuario?.email || 'sin correo' %>"
                  ></form>
                <% } %>

                <div class="user-form__actions">
                  <button
                    type="submit"
                    class="btn btn--create"
                    form="userForm"
                  >
                    <svg class="icon"><use href="#icon-check"/></svg>
                    <%= usuario ? 'Guardar cambios' : 'Crear usuario' %>
                  </button>

                  <a href="/admin/usuarios" class="btn btn--ghost">
                    Cancelar
                  </a>

                  <% if (usuario) { %>
                    <button
                      type="submit"
                      class="btn btn--danger"
                      form="deleteUserForm"
                    >
                      Eliminar
                    </button>
                  <% } %>
                </div>
              </div>
            </section>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>

  <%- include('../../partials/appModal') %>

  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>
  <script src="/js/usuarios-form-alerts.js" defer></script>
</body>
</html>