<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <!-- Hereda estilos de áreas -->
        <div class="page page--asignar page--areas page--usuarios">
          <div class="container">

            <!-- Header -->
            <div class="page-header">
              <div>
                <h1>Usuarios</h1>
                <h2><p class="page-header__sub">Cuentas de acceso al sistema</p></h2>
              </div>

              <div class="tabs-actions">
                <a href="/admin/usuarios/nuevo" class="btn btn--create btn--sm">
                  <svg class="icon"><use href="#icon-plus"/></svg>
                  Nuevo usuario
                </a>
              </div>
            </div>

            <%- include('../../partials/flash') %>

            <!-- Card filtros -->
            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Filtros</span></h3>
              </div>

              <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg);">
                <div class="form-group users-controls__field">
                  <label class="form-label" for="rolFilter">Filtrar por rol</label>
                  <select class="form-control" id="rolFilter">
                    <option value="ALL">Todos</option>
                    <option value="ADMIN">Administrador</option>
                    <option value="ENCARGADO">Encargado</option>
                    <option value="CONSULTOR">Consultor</option>
                  </select>
                </div>

                <div class="form-group users-controls__field users-controls__field--wide">
                  <label class="form-label" for="sortFilter">Orden</label>
                  <select class="form-control" id="sortFilter">
                    <option value="NEW">Creados recientemente</option>
                    <option value="OLD">Más antiguos</option>
                  </select>
                </div>

                <div class="form-group users-controls__actions">
                  <button type="button" class="btn btn--ghost btn--sm" id="resetFilters">
                    Limpiar
                  </button>
                </div>
              </div>
            </div>

            <!-- Card tabla usuarios -->
            <div class="card card--asignar card--asignar-act card--usuarios">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Usuarios registrados</span></h3>
                <span class="badge badge--ok">
                  <%= (Array.isArray(usuarios) ? usuarios.length : 0) %>
                </span>
              </div>

              <%
                const _usuarios = Array.isArray(usuarios) ? usuarios : [];
              %>

              <% if (!_usuarios.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin usuarios registrados.</p>
                </div>
              <% } else { %>

                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean" id="usersTable">
                    <thead>
                      <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Creado</th>
                        <th>Editar</th>
                      </tr>
                    </thead>

                    <tbody id="usersTbody">
                      <% _usuarios.forEach(u => { %>
                        <tr
                          data-rol="<%= u.rol %>"
                          data-created="<%= (new Date(u.createdAt)).getTime() %>"
                        >
                          <td><%= u.nombre %></td>
                          <td class="td-mono"><%= u.email %></td>

                          <td>
                            <span class="badge <%= u.rol === 'ADMIN' ? 'badge--warn' : u.rol === 'ENCARGADO' ? 'badge--ok' : 'badge--none' %>">
                              <%= u.rol %>
                            </span>
                          </td>

                          <td class="td-mono"><%= fmtDate(u.createdAt) %></td>

                          <td>
                            <a href="/admin/usuarios/<%= u.id %>/editar" class="btn btn--edit btn--sm">
                              <svg class="icon"><use href="#icon-edit"/></svg>
                              Editar
                            </a>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>

              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>

  <%- include('../../partials/appModal') %>

  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>
  <script src="/js/usuarios.js" defer></script>
</body>
</html>
