<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--usuarios">
          <div class="container">

            <div class="page-header page-header--usuarios">
              <div>
                <h1>Usuarios</h1>
                <p class="page-header__sub">Cuentas de acceso al sistema</p>
              </div>

              <!-- ✅ Arriba derecha -->
              <a href="/admin/usuarios/nuevo" class="btn btn--create">
                <svg class="icon"><use href="#icon-plus"/></svg>
                Nuevo usuario
              </a>
            </div>

            <%- include('../../partials/flash') %>

            <div class="card card--usuarios">
              <% if (!usuarios.length) { %>
                <div class="empty empty--usuarios">
                  <p class="empty__text">Sin usuarios registrados.</p>
                </div>
              <% } else { %>

                <!-- ✅ Filtros con CSS (sin inline) -->
                <div class="users-controls users-controls--light">
                  <div class="users-controls__left">
                    <div class="users-controls__field">
                      <label class="form-label" for="rolFilter">Filtrar por rol</label>
                      <select class="form-control" id="rolFilter">
                        <option value="ALL">Todos</option>
                        <option value="ADMIN">Administrador</option>
                        <option value="ENCARGADO">Encargado</option>
                        <option value="CONSULTOR">Consultor</option>
                      </select>
                    </div>

                    <div class="users-controls__field users-controls__field--wide">
                      <label class="form-label" for="sortFilter">Orden</label>
                      <select class="form-control" id="sortFilter">
                        <option value="NEW">Creados recientemente</option>
                        <option value="OLD">Más antiguos</option>
                      </select>
                    </div>

                    <div class="users-controls__actions">
                      <button type="button" class="btn btn--ghost" id="resetFilters">
                        Limpiar
                      </button>
                    </div>
                  </div>

                  <span class="badge badge--none users-controls__count" id="usersCount">0 usuarios</span>
                </div>

                <div class="table-wrap table-wrap--usuarios table-wrap--blue">
                  <table class="table table--usuarios table--blue" id="usersTable">
                    <thead>
                      <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Creado</th>
                        <th>Editar</th>
                      </tr>
                    </thead>

                    <tbody id="usersTbody">
                      <% usuarios.forEach(u => { %>
                        <tr
                          data-rol="<%= u.rol %>"
                          data-created="<%= (new Date(u.createdAt)).getTime() %>"
                        >
                          <td><%= u.nombre %></td>
                          <td class="td-mono"><%= u.email %></td>

                          <td>
                            <span class="badge <%= u.rol === 'ADMIN' ? 'badge--warn' : u.rol === 'ENCARGADO' ? 'badge--ok' : 'badge--none' %>">
                              <%= u.rol %>
                            </span>
                          </td>

                          <td class="td-mono"><%= fmtDate(u.createdAt) %></td>

                          <td>
                            <a href="/admin/usuarios/<%= u.id %>/editar" class="btn btn--edit btn--sm">
                              <svg class="icon"><use href="#icon-edit"/></svg>
                              Editar
                            </a>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>

              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>

  <%- include('../../partials/appModal') %>

  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>
  <script src="/js/usuarios.js" defer></script>
</body>
</html>