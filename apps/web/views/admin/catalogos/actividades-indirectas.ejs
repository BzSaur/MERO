<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Actividades Indirectas</h1>
                <h2><p class="page-header__sub">Catálogo de actividades sin estándar productivo</p></h2>
              </div>

              <div class="tabs-actions">
                <a href="/admin/catalogos/areas" class="btn btn--ghost btn--sm">Áreas</a>
                <a href="/admin/catalogos/subtareas" class="btn btn--ghost btn--sm">Subtareas</a>
                <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
                <a href="/admin/catalogos/estandares" class="btn btn--ghost btn--sm">Estándares</a>
              </div>
            </div>

            <%- include('../../partials/flash') %>

            <!-- Nueva actividad -->
            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Nueva actividad indirecta</span></h3>
              </div>

              <form method="POST" action="/admin/catalogos/actividades-indirectas">
                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg);">

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label" for="nombre">Nombre</label>
                    <input
                      class="form-control"
                      type="text"
                      id="nombre"
                      name="nombre"
                      required
                      placeholder="Ej: Limpieza, Capacitación, Mantenimiento"
                    >
                  </div>

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label" for="descripcion">Descripción</label>
                    <input
                      class="form-control"
                      type="text"
                      id="descripcion"
                      name="descripcion"
                      placeholder="Opcional"
                    >
                  </div>

                  <div class="form-group users-controls__actions">
                    <button type="submit" class="btn btn--edit">
                      <svg class="icon"><use href="#icon-add"/></svg>
                      Agregar
                    </button>
                  </div>

                </div>
              </form>
            </div>

            <!-- Listado -->
            <div class="card card--asignar card--asignar-act card--usuarios">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Actividades registradas</span></h3>
                <span class="badge badge--ok"><%= (actividades || []).length %></span>
              </div>

              <% if (!(actividades || []).length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin actividades indirectas.</p>
                  <p class="empty__sub">Agrega la primera usando el formulario de arriba.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Nombre</th>
                        <th class="td-hide-mobile">Descripción</th>
                        <th>Estado</th>
                        <th class="td-actions">Acciones</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% (actividades || []).forEach(a => { %>
                        <tr>
                          <td><strong><%= a.nombre %></strong></td>
                          <td class="td-hide-mobile"><%= a.descripcion || '—' %></td>
                          <td>
                            <span class="badge <%= a.activo ? 'badge--ok' : 'badge--muted' %>">
                              <%= a.activo ? 'Activa' : 'Inactiva' %>
                            </span>
                          </td>
                          <td class="td-actions">
                            <button
                              type="button"
                              class="btn btn--edit btn--sm js-edit-btn"
                              data-id="<%= a.id %>"
                              data-nombre="<%= a.nombre %>"
                              data-descripcion="<%= a.descripcion || '' %>"
                              data-activo="<%= a.activo %>"
                            >
                              Editar
                            </button>

                            <form
                              method="POST"
                              action="/admin/catalogos/actividades-indirectas/<%= a.id %>/eliminar"
                              style="display:inline"
                              class="js-form-delete"
                              data-nombre="<%= a.nombre %>"
                            >
                              <button type="submit" class="btn btn--danger btn--sm">
                                Desactivar
                              </button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <!-- Modal editar -->
  <div id="editModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); place-items:center; z-index:9999;">
    <div style="background:var(--bg-card); padding:1.5rem; border-radius:12px; width:min(480px,92vw);">
      <h3 style="margin-bottom:1rem;">Editar actividad indirecta</h3>
      <form id="editForm" method="POST">
        <div class="form-group" style="margin-bottom:.75rem;">
          <label class="form-label">Nombre</label>
          <input class="form-control" type="text" name="nombre" id="editNombre" required>
        </div>
        <div class="form-group" style="margin-bottom:.75rem;">
          <label class="form-label">Descripción</label>
          <input class="form-control" type="text" name="descripcion" id="editDescripcion">
        </div>
        <div class="form-group" style="margin-bottom:1rem;">
          <label class="form-label">
            <input type="checkbox" name="activo" value="true" id="editActivo" style="margin-right:.4rem;">
            Activa
          </label>
        </div>
        <div style="display:flex; gap:.75rem; justify-content:flex-end;">
          <button type="button" class="btn btn--ghost" id="btnCancelEdit">Cancelar</button>
          <button type="submit" class="btn btn--edit">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script>
    const modal = document.getElementById('editModal');
    const editForm = document.getElementById('editForm');

    document.querySelectorAll('.js-edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('editNombre').value = btn.dataset.nombre;
        document.getElementById('editDescripcion').value = btn.dataset.descripcion;
        document.getElementById('editActivo').checked = btn.dataset.activo === 'true';
        editForm.action = `/admin/catalogos/actividades-indirectas/${btn.dataset.id}/editar`;
        modal.style.display = 'grid';
      });
    });

    document.getElementById('btnCancelEdit')?.addEventListener('click', () => {
      modal.style.display = 'none';
    });
    modal?.addEventListener('click', e => { if (e.target === modal) modal.style.display = 'none'; });

    document.querySelectorAll('.js-form-delete').forEach(form => {
      form.addEventListener('submit', e => {
        if (!confirm(`¿Desactivar "${form.dataset.nombre}"?`)) e.preventDefault();
      });
    });
  </script>
</body>
</html>
