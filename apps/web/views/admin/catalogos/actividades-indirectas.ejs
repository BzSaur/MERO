<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Actividades Indirectas</h1>
                <h2><p class="page-header__sub">Catálogo de actividades sin estándar productivo</p></h2>
              </div>

              <div class="tabs-actions">
                <a href="/admin/catalogos/areas" class="btn btn--ghost btn--sm">Áreas</a>
                <a href="/admin/catalogos/subtareas" class="btn btn--ghost btn--sm">Subtareas</a>
                <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
                <a href="/admin/catalogos/estandares" class="btn btn--ghost btn--sm">Estándares</a>
              </div>
            </div>

            <% if (flash.error && flash.error.length) { %>
              <ul class="flash-list">
                <% flash.error.forEach(msg => { %><li class="flash flash--error"><%= msg %></li><% }) %>
              </ul>
            <% } %>
            <% if (flash.success && flash.success.length) { %>
              <script>
                document.addEventListener('DOMContentLoaded', function () {
                  Swal.fire({
                    icon: 'success',
                    title: 'Cambios guardados',
                    text: '<%= flash.success[0] %>',
                    confirmButtonText: 'Entendido',
                    confirmButtonColor: '#4f46e5'
                  });
                });
              </script>
            <% } %>

            <!-- Nueva actividad -->
            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Nueva actividad indirecta</span></h3>
              </div>

              <form method="POST" action="/admin/catalogos/actividades-indirectas">
                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg);">

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label" for="nombre">Nombre</label>
                    <input
                      class="form-control"
                      type="text"
                      id="nombre"
                      name="nombre"
                      required
                      placeholder="Ej: Limpieza, Capacitación, Mantenimiento"
                    >
                  </div>

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label" for="descripcion">Descripción</label>
                    <input
                      class="form-control"
                      type="text"
                      id="descripcion"
                      name="descripcion"
                      placeholder="Opcional"
                    >
                  </div>

                  <div class="form-group users-controls__actions">
                    <button type="submit" class="btn btn--edit">
                      <svg class="icon"><use href="#icon-add"/></svg>
                      Agregar
                    </button>
                  </div>

                </div>
              </form>
            </div>

            <!-- Listado -->
            <div class="card card--asignar card--asignar-act card--usuarios">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Actividades registradas</span></h3>
                <span class="badge badge--ok"><%= (actividades || []).length %></span>
              </div>

              <% if (!(actividades || []).length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin actividades indirectas.</p>
                  <p class="empty__sub">Agrega la primera usando el formulario de arriba.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Nombre</th>
                        <th class="td-hide-mobile">Descripción</th>
                        <th>Estado</th>
                        <th class="td-actions">Acciones</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% (actividades || []).forEach(a => { %>
                        <tr>
                          <td><strong><%= a.nombre %></strong></td>
                          <td class="td-hide-mobile"><%= a.descripcion || '—' %></td>
                          <td>
                            <span class="badge <%= a.activo ? 'badge--ok' : 'badge--muted' %>">
                              <%= a.activo ? 'Activa' : 'Inactiva' %>
                            </span>
                          </td>
                          <td class="td-actions">
                            <button
                              type="button"
                              class="btn btn--edit btn--sm js-edit-btn"
                              data-id="<%= a.id %>"
                              data-nombre="<%= a.nombre %>"
                              data-descripcion="<%= a.descripcion || '' %>"
                              data-activo="<%= a.activo %>"
                            >
                              Editar
                            </button>

                            <form
                              method="POST"
                              action="/admin/catalogos/actividades-indirectas/<%= a.id %>/eliminar"
                              style="display:inline"
                              class="js-form-delete"
                              data-nombre="<%= a.nombre %>"
                            >
                              <button type="submit" class="btn btn--danger btn--sm">
                                Desactivar
                              </button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script>
    document.querySelectorAll('.js-edit-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const id     = btn.dataset.id;
        const nombre = btn.dataset.nombre;
        const desc   = btn.dataset.descripcion;
        const activo = btn.dataset.activo === 'true';

        Swal.fire({
          title: 'Editar actividad indirecta',
          html:
            '<div style="text-align:left;display:flex;flex-direction:column;gap:.75rem;margin-top:.5rem;">' +
              '<div>' +
                '<label style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.3rem;">Nombre</label>' +
                '<input id="sw-nombre" class="swal2-input" type="text" style="margin:0;width:100%;box-sizing:border-box;" value="' + nombre.replace(/"/g,'&quot;') + '">' +
              '</div>' +
              '<div>' +
                '<label style="display:block;font-size:.85rem;font-weight:600;margin-bottom:.3rem;">Descripción</label>' +
                '<input id="sw-desc" class="swal2-input" type="text" placeholder="Opcional" style="margin:0;width:100%;box-sizing:border-box;" value="' + desc.replace(/"/g,'&quot;') + '">' +
              '</div>' +
              '<label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.875rem;">' +
                '<input id="sw-activo" type="checkbox" ' + (activo ? 'checked' : '') + ' style="width:16px;height:16px;accent-color:#4f46e5;">' +
                'Activa' +
              '</label>' +
            '</div>',
          showCancelButton: true,
          confirmButtonText: 'Guardar',
          cancelButtonText: 'Cancelar',
          confirmButtonColor: '#4f46e5',
          focusConfirm: false,
          preConfirm: function () {
            var n = document.getElementById('sw-nombre').value.trim();
            if (!n) { Swal.showValidationMessage('El nombre es requerido'); return false; }
            return {
              nombre: n,
              descripcion: document.getElementById('sw-desc').value.trim(),
              activo: document.getElementById('sw-activo').checked
            };
          }
        }).then(function (result) {
          if (!result.isConfirmed) return;
          var form = document.createElement('form');
          form.method = 'POST';
          form.action = '/admin/catalogos/actividades-indirectas/' + id + '/editar';
          [
            { name: 'nombre',      value: result.value.nombre },
            { name: 'descripcion', value: result.value.descripcion },
            { name: 'activo',      value: result.value.activo ? 'true' : '' }
          ].forEach(function (f) {
            if (f.value !== '') {
              var inp = document.createElement('input');
              inp.type = 'hidden'; inp.name = f.name; inp.value = f.value;
              form.appendChild(inp);
            }
          });
          document.body.appendChild(form);
          form.submit();
        });
      });
    });

    document.querySelectorAll('.js-form-delete').forEach(function (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var nombre = form.dataset.nombre;
        Swal.fire({
          icon: 'warning',
          title: '¿Desactivar?',
          text: '"' + nombre + '" quedará inactiva.',
          showCancelButton: true,
          confirmButtonText: 'Sí, desactivar',
          cancelButtonText: 'Cancelar',
          confirmButtonColor: '#ef4444'
        }).then(function (r) { if (r.isConfirmed) form.submit(); });
      });
    });
  </script>
</body>
</html>
