<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>
<body>
  <%- include('../../partials/icons') %>
  <%- include('../../partials/nav') %>

  <div class="page">
    <div class="container">

      <div class="page-header">
        <div>
          <h1>Áreas</h1>
          <p class="page-header__sub"><h4>Zonas de producción</p></h4>
        </div>
        <div style="display:flex; gap:var(--gap-sm); flex-wrap:wrap">
          <a href="/admin/catalogos/subtareas" class="btn btn--ghost btn--sm">Subtareas</a>
          <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
          <a href="/admin/catalogos/estandares" class="btn btn--ghost btn--sm">Estandares</a>
        </div>
      </div>

      <%- include('../../partials/flash') %>

      <div class="grid-2" style="align-items:start">

        <%# ── Formulario nueva area ── %>
        <div class="card">
          <div class="card__header">
            <span class="card__title">Nueva área</span>
          </div>
          <form method="POST" action="/admin/catalogos/areas">
            <div class="form-group">
              <label class="form-label" for="nombre">Nombre</label>
              <input class="form-control" type="text" id="nombre" name="nombre" required placeholder="Ej: Laboratorio Test">
            </div>
            <div class="form-group">
              <label class="form-label" for="descripcion">Descripción</label>
              <input class="form-control" type="text" id="descripcion" name="descripcion" placeholder="Opcional">
            </div>
            <button type="submit" class="btn btn--primary">
              <svg class="icon"><use href="#icon-plus"/></svg>
              Crear área
            </button>
          </form>
        </div>

        <%# ── Listado ── %>
        <div class="card">
          <div class="card__header">
            <span class="card__title">Áreas registradas</span>
            <span class="badge badge--none"><%= areas.length %></span>
          </div>
          <% if (!areas.length) { %>
            <div class="empty"><p class="empty__text">Sin áreas registradas.</p></div>
          <% } else { %>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr><th>#</th><th>Nombre</th><th>Descripción</th><th></th></tr>
                </thead>
                <tbody>
                  <% areas.forEach(a => { %>
                    <tr>
                      <td class="td-mono"><%= a.id %></td>
                      <td><%= a.nombre %></td>
                      <td style="color:var(--ink-dim)"><%= a.descripcion || '—' %></td>
                      <td>
                        <form method="POST" action="/admin/catalogos/areas/<%= a.id %>/eliminar"
                              onsubmit="return confirm('¿Eliminar área «<%= a.nombre %>»?')">
                          <button type="submit" class="btn btn--danger btn--sm">
                            <svg class="icon"><use href="#icon-trash"/></svg>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</body>
</html>
