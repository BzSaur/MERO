<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Áreas</h1>
                <h2><p class="page-header__sub">Zonas de producción</p></h2>
              </div>

              <div class="tabs-actions">
                <a href="/admin/catalogos/subtareas" class="btn btn--ghost btn--sm">Subtareas</a>
                <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
                <a href="/admin/catalogos/estandares" class="btn btn--ghost btn--sm">Estándares</a>
              </div>
            </div>

            <%- include('../../partials/flash') %>

            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Nueva área</span></h3>
              </div>

              <form method="POST" action="/admin/catalogos/areas">
                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg);">

                  <div class="form-group users-controls__field">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" type="text" id="nombre" name="nombre" required placeholder="Ej: Laboratorio Test">
                  </div>

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label">Descripción</label>
                    <input class="form-control" type="text" id="descripcion" name="descripcion" placeholder="Opcional">
                  </div>

                  <div class="form-group users-controls__actions">
                    <button type="submit" class="btn btn--create btn--sm">
                      <svg class="icon"><use href="#icon-plus"/></svg>
                      Crear área
                    </button>
                  </div>

                </div>
              </form>
            </div>

           <div class="card card--asignar card--asignar-act">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Áreas registradas</span></h3>
                <span class="badge badge--ok"><%= areas.length %></span>
              </div>

              <% if (!areas.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin áreas registradas.</p>
                </div>
              <% } else { %>

                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th></th>
                      </tr>
                    </thead>

                    <tbody>
                      <% areas.forEach(a => { %>
                        <tr>
                          <td class="td-mono"><%= a.id %></td>
                          <td><%= a.nombre %></td>
                          <td><%= a.descripcion || '—' %></td>

                          <td>
                            <div class="row-actions">

                              <button
                                type="button"
                                class="btn btn--edit btn--sm btn--icon"
                                title="Editar"
                                data-edit-kind="area"
                                data-update-action="/admin/catalogos/areas/<%= a.id %>/editar"
                                data-id="<%= a.id %>"
                                data-nombre="<%= a.nombre %>"
                                data-descripcion="<%= a.descripcion || '' %>"
                              >
                                <svg class="icon"><use href="#icon-edit"/></svg>
                              </button>

                              <form
                                method="POST"
                                action="/admin/catalogos/areas/<%= a.id %>/eliminar"
                                data-confirm-delete
                                data-kind="area"
                                data-nombre="<%= a.nombre %>"
                                data-descripcion="<%= a.descripcion || '—' %>"
                              >
                                <button type="submit" class="btn btn--danger btn--sm btn--icon" title="Eliminar">
                                  <svg class="icon"><use href="#icon-trash"/></svg>
                                </button>
                              </form>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>
</body>
</html>