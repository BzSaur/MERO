<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Estándares</h1>
                <h2><p class="page-header__sub">Producción esperada por hora (subtarea + modelo)</p></h2>
              </div>

              <div class="tabs-actions">
                <a href="/admin/catalogos/areas" class="btn btn--ghost btn--sm">Áreas</a>
                <a href="/admin/catalogos/subtareas" class="btn btn--ghost btn--sm">Subtareas</a>
                <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
                <a href="/admin/catalogos/actividades-indirectas" class="btn btn--ghost btn--sm">Indirectas</a>
              </div>
            </div>

            <%- include('../../partials/flash') %>

            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Nuevo estándar</span></h3>
              </div>

              <form method="POST" action="/admin/catalogos/estandares" id="formEstandar">
                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg); flex-wrap:wrap; gap:var(--gap);">

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label" for="subtareaId">Subtarea</label>
                    <select class="form-control" id="subtareaId" name="subtareaId" required>
                      <option value="">— Seleccionar —</option>
                      <% subtareas.forEach(s => { %>
                        <option value="<%= s.id %>">
                          <%= s.area?.nombre || 'Sin área' %> / <%= s.nombre %>
                        </option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="form-group" style="flex:1 1 100%;">
                    <label class="form-label">
                      Modelos
                      <span style="font-weight:400; color:var(--ink-dim); font-size:.78rem;">(selecciona uno o varios — mismo estándar para todos)</span>
                    </label>
                    <div id="modelosCheckboxes" style="display:flex; flex-wrap:wrap; gap:.5rem .75rem; padding:.5rem 0;">
                      <% modelos.forEach(m => { %>
                        <label style="display:flex; align-items:center; gap:.35rem; cursor:pointer; font-size:.875rem; padding:.2rem .5rem; border-radius:4px; border:1px solid var(--border); background:var(--surface);">
                          <input type="checkbox" name="modeloIds" value="<%= m.id %>" style="accent-color:var(--accent);">
                          <%= m.nombreSku %>
                        </label>
                      <% }) %>
                    </div>
                  </div>

                  <div class="form-group users-controls__field">
                    <label class="form-label" for="piezasPorHora">Unidades / hora</label>
                    <input
                      class="form-control"
                      type="number"
                      id="piezasPorHora"
                      name="piezasPorHora"
                      min="1"
                      required
                      placeholder="50"
                    >
                  </div>

                  <div class="form-group users-controls__field">
                    <label class="form-label" for="vigenteDesde">Vigente desde</label>
                    <%
                      const pad2 = (n) => String(n).padStart(2, '0');
                      const hoy = new Date();
                      const hoyStr = `${hoy.getFullYear()}-${pad2(hoy.getMonth() + 1)}-${pad2(hoy.getDate())}`;
                    %>
                    <input
                      class="form-control"
                      type="date"
                      id="vigenteDesde"
                      name="vigenteDesde"
                      required
                      max="<%= hoyStr %>"
                    >
                  </div>

                  <div class="form-group users-controls__actions" style="align-self:flex-end;">
                    <button type="submit" class="btn btn--create btn--sm">
                      <svg class="icon"><use href="#icon-plus"/></svg>
                      Guardar estándar
                    </button>
                  </div>

                </div>
              </form>
              <script>
                document.getElementById('formEstandar').addEventListener('submit', function(e) {
                  const checked = this.querySelectorAll('input[name="modeloIds"]:checked');
                  if (!checked.length) {
                    e.preventDefault();
                    Swal.fire({
                      icon: 'warning',
                      title: 'Sin modelo',
                      text: 'Selecciona al menos un modelo antes de guardar.',
                      confirmButtonText: 'Entendido',
                      confirmButtonColor: 'var(--accent, #4f46e5)'
                    });
                  }
                });
              </script>
            </div>

            <div class="card card--asignar card--asignar-act">
              <div class="card__header card__header--usuarios" style="flex-direction:column; align-items:stretch; gap:.6rem;">
                <div style="display:flex; align-items:center; gap:.5rem;">
                  <h3><span class="card__title">Estándares registrados</span></h3>
                  <span class="badge badge--ok" id="badgeCount"><%= estandares.length %></span>
                </div>
                <div style="display:flex; gap:.5rem; align-items:center; flex-wrap:wrap;">
                  <input
                    id="filterNombre"
                    type="text"
                    placeholder="Filtrar por nombre…"
                    class="form-control form-control--sm"
                    style="flex:1 1 140px; min-width:0;"
                  >

                  <!-- Custom multi-select dropdown for modelo -->
                  <div id="modeloDropdownWrap" style="position:relative; flex:1 1 140px; min-width:0;">
                    <button
                      type="button"
                      id="modeloDropdownBtn"
                      class="form-control form-control--sm"
                      style="width:100%; text-align:left; cursor:pointer; display:flex; justify-content:space-between; align-items:center; white-space:nowrap; overflow:hidden;"
                      aria-expanded="false"
                    >
                      <span id="modeloDropdownLabel" style="overflow:hidden; text-overflow:ellipsis;">Todos los modelos</span>
                      <svg style="width:12px;height:12px;flex-shrink:0;margin-left:.4rem;" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 1l4 4 4-4"/></svg>
                    </button>

                    <div
                      id="modeloDropdownPanel"
                      style="display:none; position:fixed; z-index:9999; background:var(--surface,#fff); border:1px solid var(--border,#e2e8f0); border-radius:8px; box-shadow:0 8px 24px rgba(0,0,0,.15); min-width:210px; max-height:280px; overflow-y:auto; padding:.4rem 0;"
                    >
                      <% modelos.forEach(m => { %>
                        <label style="display:flex; align-items:center; gap:.5rem; padding:.35rem .85rem; cursor:pointer; font-size:.85rem; white-space:nowrap;" class="dropdown-opt">
                          <input type="checkbox" class="modelo-filter-cb" value="<%= m.nombreSku.toLowerCase() %>" style="accent-color:var(--accent);">
                          <%= m.nombreSku %>
                        </label>
                      <% }) %>
                    </div>
                  </div>
                </div>
              </div>

              <% if (!estandares.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin estándares registrados.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table id="tablaEstandares" class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Subtarea</th>
                        <th>Modelo</th>
                        <th>Unid/h</th>
                        <th class="td-hide-mobile">Vigente desde</th>
                        <th></th>
                      </tr>
                    </thead>

                    <tbody>
                      <% estandares.forEach(e => {
                        const vigenteISO = e.vigenteDesde ? new Date(e.vigenteDesde).toISOString().slice(0, 10) : '';
                        const vigenteMX = e.vigenteDesde ? new Date(e.vigenteDesde).toLocaleDateString('es-MX') : '—';
                        const subt = `${e.subtarea?.area?.nombre || 'Sin área'} / ${e.subtarea?.nombre || ''}`.trim();
                        const mod = e.modelo?.nombreSku || '—';
                      %>
                        <tr data-nombre="<%= subt.toLowerCase() %>" data-modelo="<%= mod.toLowerCase() %>">
                          <td>
                            <span style="font-size:.78rem; color:var(--ink-dim)">
                              <%= e.subtarea?.area?.nombre || 'Sin área' %> /
                            </span>
                            <%= e.subtarea?.nombre || '—' %>
                          </td>
                          <td><%= mod %></td>
                          <td class="td-mono"><%= e.piezasPorHora %></td>
                          <td class="td-mono td-hide-mobile"><%= vigenteMX %></td>
                          <td>
                            <div class="row-actions">
                              <button
                                type="button"
                                class="btn btn--edit btn--sm btn--icon"
                                title="Editar"
                                data-edit-kind="estandar"
                                data-update-action="/admin/catalogos/estandares/<%= e.id %>/editar"
                                data-id="<%= e.id %>"
                                data-subtarea="<%= subt %>"
                                data-modelo="<%= mod %>"
                                data-cantidad="<%= e.piezasPorHora %>"
                                data-vigente="<%= vigenteISO %>"
                                data-vigente-mx="<%= vigenteMX %>"
                              >
                                <svg class="icon"><use href="#icon-edit"/></svg>
                              </button>

                              <form
                                method="POST"
                                action="/admin/catalogos/estandares/<%= e.id %>/eliminar"
                                data-confirm-delete
                                data-kind="estandar"
                                data-subtarea="<%= subt %>"
                                data-modelo="<%= mod %>"
                                data-cantidad="<%= e.piezasPorHora %>"
                                data-vigente="<%= vigenteMX %>"
                              >
                                <button type="submit" class="btn btn--danger btn--sm btn--icon" title="Eliminar">
                                  <svg class="icon"><use href="#icon-trash"/></svg>
                                </button>
                              </form>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>
  <script>
    (function () {
      const filterNombre   = document.getElementById('filterNombre');
      const badge          = document.getElementById('badgeCount');
      const dropBtn        = document.getElementById('modeloDropdownBtn');
      const dropPanel      = document.getElementById('modeloDropdownPanel');
      const dropLabel      = document.getElementById('modeloDropdownLabel');
      const checkboxes     = document.querySelectorAll('.modelo-filter-cb');

      // Toggle panel — position fixed under button
      dropBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        const open = dropPanel.style.display === 'block';
        if (!open) {
          const rect = dropBtn.getBoundingClientRect();
          dropPanel.style.top  = (rect.bottom + 4) + 'px';
          dropPanel.style.left = 'auto';
          dropPanel.style.right = (window.innerWidth - rect.right) + 'px';
        }
        dropPanel.style.display = open ? 'none' : 'block';
        dropBtn.setAttribute('aria-expanded', String(!open));
      });

      // Close on outside click
      document.addEventListener('click', function (e) {
        if (!document.getElementById('modeloDropdownWrap').contains(e.target)) {
          dropPanel.style.display = 'none';
          dropBtn.setAttribute('aria-expanded', 'false');
        }
      });

      // Hover highlight
      document.querySelectorAll('.dropdown-opt').forEach(function (lbl) {
        lbl.addEventListener('mouseenter', function () { lbl.style.background = 'var(--surface-hover, #f3f4f6)'; });
        lbl.addEventListener('mouseleave', function () { lbl.style.background = ''; });
      });

      function getSelectedModelos() {
        return Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
      }

      function updateLabel(selected) {
        if (!selected.length) {
          dropLabel.textContent = 'Todos los modelos';
        } else if (selected.length === 1) {
          dropLabel.textContent = checkboxes[Array.from(checkboxes).findIndex(cb => cb.value === selected[0])].closest('label').textContent.trim();
        } else {
          dropLabel.textContent = selected.length + ' modelos';
        }
      }

      function applyFilters() {
        const nombre   = filterNombre.value.toLowerCase().trim();
        const selected = getSelectedModelos();
        const rows     = document.querySelectorAll('#tablaEstandares tbody tr');
        let visible    = 0;

        rows.forEach(function (row) {
          const matchNombre = !nombre   || row.dataset.nombre.includes(nombre);
          const matchModelo = !selected.length || selected.includes(row.dataset.modelo);
          const show = matchNombre && matchModelo;
          row.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (badge) badge.textContent = visible;
      }

      filterNombre.addEventListener('input', applyFilters);
      checkboxes.forEach(function (cb) {
        cb.addEventListener('change', function () {
          updateLabel(getSelectedModelos());
          applyFilters();
        });
      });
    })();
  </script>
</body>
</html>