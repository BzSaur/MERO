<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Estándares</h1>
                <h2><p class="page-header__sub">Producción esperada por hora (subtarea + modelo)</p></h2>
              </div>

              <div class="tabs-actions">
                <a href="/admin/catalogos/areas" class="btn btn--ghost btn--sm">Áreas</a>
                <a href="/admin/catalogos/subtareas" class="btn btn--ghost btn--sm">Subtareas</a>
                <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
                <a href="/admin/catalogos/actividades-indirectas" class="btn btn--ghost btn--sm">Indirectas</a>
              </div>
            </div>

            <%- include('../../partials/flash') %>

            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Nuevo estándar</span></h3>
              </div>

              <form method="POST" action="/admin/catalogos/estandares" id="formEstandar">
                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg); flex-wrap:wrap; gap:var(--gap);">

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label" for="subtareaId">Subtarea</label>
                    <select class="form-control" id="subtareaId" name="subtareaId" required>
                      <option value="">— Seleccionar —</option>
                      <% subtareas.forEach(s => { %>
                        <option value="<%= s.id %>">
                          <%= s.area?.nombre || 'Sin área' %> / <%= s.nombre %>
                        </option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="form-group" style="flex:1 1 100%;">
                    <label class="form-label">
                      Modelos
                      <span style="font-weight:400; color:var(--ink-dim); font-size:.78rem;">(selecciona uno o varios — mismo estándar para todos)</span>
                    </label>
                    <div id="modelosCheckboxes" style="display:flex; flex-wrap:wrap; gap:.5rem .75rem; padding:.5rem 0;">
                      <% modelos.forEach(m => { %>
                        <label style="display:flex; align-items:center; gap:.35rem; cursor:pointer; font-size:.875rem; padding:.2rem .5rem; border-radius:4px; border:1px solid var(--border); background:var(--surface);">
                          <input type="checkbox" name="modeloIds" value="<%= m.id %>" style="accent-color:var(--accent);">
                          <%= m.nombreSku %>
                        </label>
                      <% }) %>
                    </div>
                    <p id="modelosError" style="display:none; color:var(--danger); font-size:.8rem; margin-top:.25rem;">Selecciona al menos un modelo.</p>
                  </div>

                  <div class="form-group users-controls__field">
                    <label class="form-label" for="piezasPorHora">Unidades / hora</label>
                    <input
                      class="form-control"
                      type="number"
                      id="piezasPorHora"
                      name="piezasPorHora"
                      min="1"
                      required
                      placeholder="50"
                    >
                  </div>

                  <div class="form-group users-controls__field">
                    <label class="form-label" for="vigenteDesde">Vigente desde</label>
                    <%
                      const pad2 = (n) => String(n).padStart(2, '0');
                      const hoy = new Date();
                      const hoyStr = `${hoy.getFullYear()}-${pad2(hoy.getMonth() + 1)}-${pad2(hoy.getDate())}`;
                    %>
                    <input
                      class="form-control"
                      type="date"
                      id="vigenteDesde"
                      name="vigenteDesde"
                      required
                      max="<%= hoyStr %>"
                    >
                  </div>

                  <div class="form-group users-controls__actions" style="align-self:flex-end;">
                    <button type="submit" class="btn btn--create btn--sm">
                      <svg class="icon"><use href="#icon-plus"/></svg>
                      Guardar estándar
                    </button>
                  </div>

                </div>
              </form>
              <script>
                document.getElementById('formEstandar').addEventListener('submit', function(e) {
                  const checked = this.querySelectorAll('input[name="modeloIds"]:checked');
                  if (!checked.length) {
                    e.preventDefault();
                    document.getElementById('modelosError').style.display = 'block';
                  } else {
                    document.getElementById('modelosError').style.display = 'none';
                  }
                });
              </script>
            </div>

            <div class="card card--asignar card--asignar-act">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Estándares registrados</span></h3>
                <span class="badge badge--ok"><%= estandares.length %></span>
              </div>

              <% if (!estandares.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin estándares registrados.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Subtarea</th>
                        <th>Modelo</th>
                        <th>Unid/h</th>
                        <th class="td-hide-mobile">Vigente desde</th>
                        <th></th>
                      </tr>
                    </thead>

                    <tbody>
                      <% estandares.forEach(e => {
                        const vigenteISO = e.vigenteDesde ? new Date(e.vigenteDesde).toISOString().slice(0, 10) : '';
                        const vigenteMX = e.vigenteDesde ? new Date(e.vigenteDesde).toLocaleDateString('es-MX') : '—';
                        const subt = `${e.subtarea?.area?.nombre || 'Sin área'} / ${e.subtarea?.nombre || ''}`.trim();
                        const mod = e.modelo?.nombreSku || '—';
                      %>
                        <tr>
                          <td>
                            <span style="font-size:.78rem; color:var(--ink-dim)">
                              <%= e.subtarea?.area?.nombre || 'Sin área' %> /
                            </span>
                            <%= e.subtarea?.nombre || '—' %>
                          </td>
                          <td><%= mod %></td>
                          <td class="td-mono"><%= e.piezasPorHora %></td>
                          <td class="td-mono td-hide-mobile"><%= vigenteMX %></td>
                          <td>
                            <div class="row-actions">
                              <button
                                type="button"
                                class="btn btn--edit btn--sm btn--icon"
                                title="Editar"
                                data-edit-kind="estandar"
                                data-update-action="/admin/catalogos/estandares/<%= e.id %>/editar"
                                data-id="<%= e.id %>"
                                data-subtarea="<%= subt %>"
                                data-modelo="<%= mod %>"
                                data-cantidad="<%= e.piezasPorHora %>"
                                data-vigente="<%= vigenteISO %>"
                                data-vigente-mx="<%= vigenteMX %>"
                              >
                                <svg class="icon"><use href="#icon-edit"/></svg>
                              </button>

                              <form
                                method="POST"
                                action="/admin/catalogos/estandares/<%= e.id %>/eliminar"
                                data-confirm-delete
                                data-kind="estandar"
                                data-subtarea="<%= subt %>"
                                data-modelo="<%= mod %>"
                                data-cantidad="<%= e.piezasPorHora %>"
                                data-vigente="<%= vigenteMX %>"
                              >
                                <button type="submit" class="btn btn--danger btn--sm btn--icon" title="Eliminar">
                                  <svg class="icon"><use href="#icon-trash"/></svg>
                                </button>
                              </form>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>
</body>
</html>