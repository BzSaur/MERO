<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../../partials/icons') %>

  <div class="wrapper">
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <%- include('../../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Subtareas</h1>
                <h2><p class="page-header__sub">Actividades por área</p></h2>
              </div>

              <div class="tabs-actions">
                <a href="/admin/catalogos/areas" class="btn btn--ghost btn--sm">Áreas</a>
                <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
                <a href="/admin/catalogos/estandares" class="btn btn--ghost btn--sm">Estándares</a>
              </div>
            </div>

            <%- include('../../partials/flash') %>

            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Nueva subtarea</span></h3>
              </div>

              <form method="POST" action="/admin/catalogos/subtareas">
                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg);">

                  <div class="form-group users-controls__field">
                    <label class="form-label" for="areaId">Área</label>
                    <select class="form-control" id="areaId" name="areaId" required>
                      <option value="">— Seleccionar —</option>
                      <% areas.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.nombre %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="form-group users-controls__field">
                    <label class="form-label" for="nombre">Nombre</label>
                    <input class="form-control" type="text" id="nombre" name="nombre" required placeholder="Ej: Test Visual">
                  </div>

                  <div class="form-group users-controls__field users-controls__field--wide">
                    <label class="form-label" for="descripcion">Descripción</label>
                    <input class="form-control" type="text" id="descripcion" name="descripcion" placeholder="Opcional">
                  </div>

                  <div class="form-group users-controls__actions">
                    <button type="submit" class="btn btn--create btn--sm">
                      <svg class="icon"><use href="#icon-plus"/></svg>
                      Crear subtarea
                    </button>
                  </div>
                </div>
              </form>
            </div>

            <div class="card card--asignar card--asignar-act">
              <div class="card__header">
                <h3><span class="card__title">Subtareas registradas</span></h3>
                <span class="badge badge--ok"><%= subtareas.length %></span>
              </div>

              <% if (!subtareas.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin subtareas registradas.</p>
                </div>
              <% } else { %>

                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Área</th>
                        <th>Subtarea</th>
                        <th>Descripción</th>
                        <th></th>
                      </tr>
                    </thead>

                    <tbody>
                      <% subtareas.forEach(s => { %>
                        <tr>
                          <td><%= s.area?.nombre || '—' %></td>
                          <td><%= s.nombre %></td>
                          <td><%= s.descripcion || '—' %></td>
                          <td>
                            <div class="row-actions">

                              <button
                                type="button"
                                class="btn btn--edit btn--sm btn--icon"
                                title="Editar"
                                data-edit-kind="subtarea"
                                data-update-action="/admin/catalogos/subtareas/<%= s.id %>/editar"
                                data-id="<%= s.id %>"
                                data-area="<%= s.area?.nombre || '—' %>"
                                data-nombre="<%= s.nombre %>"
                                data-descripcion="<%= s.descripcion || '' %>"
                              >
                                <svg class="icon"><use href="#icon-edit"/></svg>
                              </button>

                              <form
                                method="POST"
                                action="/admin/catalogos/subtareas/<%= s.id %>/eliminar"
                                data-confirm-delete
                                data-kind="subtarea"
                                data-area="<%= s.area?.nombre || '—' %>"
                                data-nombre="<%= s.nombre %>"
                                data-descripcion="<%= s.descripcion || '—' %>"
                              >
                                <button type="submit" class="btn btn--danger btn--sm btn--icon" title="Eliminar">
                                  <svg class="icon"><use href="#icon-trash"/></svg>
                                </button>
                              </form>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>
</body>
</html>