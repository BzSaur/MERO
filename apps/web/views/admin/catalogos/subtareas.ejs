<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head') %>
</head>
<body>
  <%- include('../../partials/icons') %>
  <%- include('../../partials/nav') %>

  <div class="page page--asignar">
    <div class="container">

      <div class="page-header">
        <div>
          <h1>Subtareas</h1>
          <p class="page-header__sub"><h4>Actividades por área</h4></p>
        </div>
        <div style="display:flex; gap:var(--gap-sm); flex-wrap:wrap">
          <a href="/admin/catalogos/areas" class="btn btn--ghost btn--sm">Areas</a>
          <a href="/admin/catalogos/modelos" class="btn btn--ghost btn--sm">Modelos</a>
          <a href="/admin/catalogos/estandares" class="btn btn--ghost btn--sm">Estandares</a>
        </div>
      </div>

      <%- include('../../partials/flash') %>

      <div class="grid-2" style="align-items:start">

        <div class="card card--asignar">
          <div class="card__header">
            <span class="card__title">Nueva subtarea</span>
          </div>
          <form method="POST" action="/admin/catalogos/subtareas">
            <div class="form-group">
              <label class="form-label" for="areaId">Área</label>
              <select class="form-control" id="areaId" name="areaId" required>
                <option value="">— Seleccionar —</option>
                <% areas.forEach(a => { %>
                  <option value="<%= a.id %>"><%= a.nombre %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="nombre">Nombre</label>
              <input class="form-control" type="text" id="nombre" name="nombre" required placeholder="Ej: Test Visual">
            </div>
            <div class="form-group">
              <label class="form-label" for="descripcion">Descripción</label>
              <input class="form-control" type="text" id="descripcion" name="descripcion" placeholder="Opcional">
            </div>
            <button type="submit" class="btn btn--primary">
              <svg class="icon"><use href="#icon-plus"/></svg>
              Crear subtarea
            </button>
          </form>
        </div>

        <div class="card card--asignar card--asignar-act">
          <div class="card__header">
            <span class="card__title">Subtareas registradas</span>
            <span class="badge badge--ok"><%= subtareas.length %></span>
          </div>

          <% if (!subtareas.length) { %>
            <div class="empty empty--asignar">
              <p class="empty__text">Sin subtareas registradas.</p>
            </div>
          <% } else { %>
            <div class="table-wrap table-wrap--asignar">
              <table class="table table--asignar">
                <thead>
                  <tr><th>Área</th><th>Subtarea</th><th>Descripción</th></tr>
                </thead>
                <tbody>
                  <% subtareas.forEach(s => { %>
                    <tr>
                     <td><%= s.area?.nombre || '—' %></td>
                     <td><%= s.descripcion || '—' %></td>  
                      <td><%= s.nombre %></td>
                      <td style="color:var(--ink-dim)"><%= s.descripcion || '—' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</body>
</html>