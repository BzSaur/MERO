<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/cards.css">
  <link rel="stylesheet" href="/css/ui.css">
  <link rel="stylesheet" href="/css/buttons.css">
  <link rel="stylesheet" href="/css/dark.css">
</head>

<body class="sidebar-collapsed">
  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <nav class="navbar">
        <button class="btn-icon" id="sidebarToggle" title="Menú">
          <i class="bi bi-list"></i>
        </button>
        <h1 class="page-title">Panel Administrador</h1>
        
        <div class="ms-auto">
          <div class="user-dropdown" id="userDropdown">
            <div class="user-dropdown-toggle" onclick="toggleUserMenu()">
              <div class="user-avatar"><span>A</span></div>
              <span class="user-name d-none d-md-inline">Administrador</span>
              <i class="bi bi-chevron-down" style="color: #94a3b8; font-size: 0.8rem;"></i>
            </div>
            
            <div class="dropdown-menu" id="userMenu">
              <div class="dropdown-header">
                <strong>Administrador</strong>
                <small>admin@mero.com</small>
              </div>
              <div class="dropdown-divider"></div>
              <a href="/auth/logout" class="dropdown-item text-danger">
                <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
              </a>
            </div>
          </div>
        </div>
      </nav>

      <main class="dashboard-content">
        <%- include('../partials/flash') %>

        <%
          const totalAsignados = (asignaciones || []).length;
          let sumEff = 0, countEff = 0;
          (metricas || []).forEach(m => {
            if (m.eficienciaPct != null) { sumEff += Number(m.eficienciaPct); countEff++; }
          });
          const avgEff = countEff ? (sumEff / countEff) : null;
          const okCount = (metricas || []).filter(m => m.eficienciaPct >= 90).length;
          const warnCount = (metricas || []).filter(m => m.eficienciaPct >= 70 && m.eficienciaPct < 90).length;
          const failCount = (metricas || []).filter(m => m.eficienciaPct > 0 && m.eficienciaPct < 70).length;

          const areasActivas = [...new Set(
            (metricas || []).map(m =>
              m.areaNombre ||
              m.area?.nombre ||
              (typeof m.area === 'string' ? m.area : null) ||
              'Área'
            )
          )].length;
          
          const hoy = new Date().toLocaleDateString('es-MX', { 
            weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
          });
        %>

        <div class="welcome-header d-flex justify-content-between align-items-start mb-4">
          <div>
            <h2 style="font-weight: 800; font-size: 1.8rem;">¡Bienvenido, Administrador!</h2>
            <p>Panel de control MERO - Métricas y Eficiencia Operativa</p>
          </div>
          <div class="date-badge">
            <i class="bi bi-calendar3 me-2"></i><%= hoy %>
          </div>
        </div>

        <div class="grid-stats--metrics mb-4">
          <div class="stat-card--gradient stat-card--blue">
            <div class="stat-card__label">Empleados Activos</div>
            <div class="stat-card__value"><%= totalAsignados %></div>
            <div class="stat-card__sub">En planta ahora</div>
          </div>

          <div class="stat-card--gradient stat-card--green">
            <div class="stat-card__label">Eficiencia Promedio</div>
            <div class="stat-card__value"><%= avgEff ? avgEff.toFixed(0) + '%' : '0%' %></div>
            <div class="stat-card__sub">Todos los slots de hoy</div>
          </div>

          <div class="stat-card--gradient stat-card--indigo">
            <div class="stat-card__label">Slots en Verde</div>
            <div class="stat-card__value"><%= okCount %></div>
            <div class="stat-card__sub">Eficiencia > 90%</div>
          </div>

          <div class="stat-card--gradient stat-card--orange">
            <div class="stat-card__label">Áreas Activas</div>
            <div class="stat-card__value"><%= areasActivas %></div>
            <div class="stat-card__sub">Con registro hoy</div>
          </div>
        </div>

        <div class="card mb-4" style="border-radius: 18px;">
          <div class="card-body py-2">
            <div class="d-flex align-items-center gap-3 flex-wrap">
              <span class="badge-summary">
                <i class="bi bi-circle-fill text-success" style="font-size: 0.6rem;"></i> Verde (≥90%): <%= okCount %>
              </span>
              <span class="badge-summary">
                <i class="bi bi-circle-fill text-warning" style="font-size: 0.6rem;"></i> Riesgo (70-89%): <%= warnCount %>
              </span>
              <span class="badge-summary">
                <i class="bi bi-circle-fill text-danger" style="font-size: 0.6rem;"></i> Crítico (&lt;70%): <%= failCount %>
              </span>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-12 col-lg-3">
            <div class="card h-100">
              <div class="card-header bg-transparent border-bottom-0 pb-0">
                <h5 class="card-title"><i class="bi bi-lightning-charge me-2" style="color: #f59e0b;"></i> Acciones Rápidas</h5>
              </div>
              <div class="card-body d-grid gap-2">
                <a href="/admin/usuarios" class="quick-btn is-blue"><i class="bi bi-people"></i> Usuarios</a>
                <a href="/encargado/captura" class="quick-btn is-green"><i class="bi bi-clipboard-check"></i> Registrar Captura</a>
                <a href="/admin/catalogos/areas" class="quick-btn is-cyan"><i class="bi bi-diagram-3"></i> Nueva Área</a>
                <a href="/admin/catalogos/subtareas" class="quick-btn is-amber"><i class="bi bi-list-check"></i> Nueva Subárea</a>
                <a href="/consultor/historico" class="quick-btn is-gray"><i class="bi bi-bar-chart"></i> Ver Reportes</a>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-9">
            <div class="card h-100">
              <div class="card-header card-header--eficiencia bg-transparent border-bottom-0 pb-0">
                <h5 class="card-title mb-0">
                  <i class="bi bi-bar-chart-line me-2" style="color: #3b82f6;"></i>
                  Eficiencia por área
                </h5>
                <a href="/consultor" class="btn--manage" style="font-size: 0.75rem;">Ver métricas →</a>
              </div>

              <% if ((metricas || []).length > 0) { %>
                <%
                  function effClass(v) {
                    if (v == null || !Number.isFinite(Number(v))) return 'none';
                    const n = Number(v);
                    if (n >= 90) return 'ok';
                    if (n >= 70) return 'warn';
                    return 'fail';
                  }
                  function fmtEff(v) {
                    if (v == null || !Number.isFinite(Number(v))) return '—';
                    return Number(v).toFixed(1) + '%';
                  }
                  function avgArr(arr) {
                    const valid = arr.filter(x => x != null && Number.isFinite(Number(x)));
                    return valid.length ? valid.reduce((s,x) => s + Number(x), 0) / valid.length : null;
                  }

                  // Construir árbol: área → subtarea → empleado → [registros]
                  const tree = {};
                  (metricas || []).forEach(m => {
                    const area = m.area || m.areaNombre || 'Sin área';
                    const sub  = m.subtarea || m.subtareaNombre || 'Sin subtarea';
                    const emp  = m.empleado || m.empleadoNombre || '—';
                    if (!tree[area]) tree[area] = {};
                    if (!tree[area][sub]) tree[area][sub] = {};
                    if (!tree[area][sub][emp]) tree[area][sub][emp] = [];
                    tree[area][sub][emp].push(m);
                  });

                  // Mapa de rechazos por asignacionId
                  const _capturasMap = capturasMap || {};
                  const _rechByAsig = {};
                  (asignaciones || []).forEach(function(a) {
                    const caps = _capturasMap[a.id] || [];
                    let totalRec = 0, okConRec = 0;
                    caps.forEach(function(c) {
                      const recs = (c.rechazos || []).reduce(function(s,r) { return s + r.cantidad; }, 0);
                      if (recs > 0) { totalRec += recs; okConRec++; }
                    });
                    _rechByAsig[a.id] = { totalRec, okConRec };
                  });
                %>

                <div class="card-body" style="padding:0;">
                  <table class="table table--clean rexp-table">
                    <thead>
                      <tr>
                        <th style="width:2rem"></th>
                        <th>Área / Subtarea / Empleado</th>
                        <th style="width:7rem;text-align:right">Eficiencia</th>
                        <th style="width:10rem" class="td-hide-mobile">Slots hoy</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% let areaIdx = 0; Object.entries(tree).forEach(([area, subs]) => {
                           const allRecs = Object.values(subs).flatMap(em => Object.values(em).flat());
                           const areaAvg = avgArr(allRecs.map(m => m.eficienciaPct ?? m.eficiencia ?? null));
                           const allSlots = allRecs.slice().sort((a,b) => (a.slotHora??0)-(b.slotHora??0));
                           const aId = 'area-' + areaIdx++;
                           // Rechazos del área
                           let areaTotalRec = 0, areaOkConRec = 0;
                           (asignaciones || []).forEach(a => {
                             if ((a.area?.nombre || '') === area) {
                               const rd = _rechByAsig[a.id] || {};
                               areaTotalRec += rd.totalRec || 0;
                               areaOkConRec += rd.okConRec || 0;
                             }
                           });
                      %>
                        <!-- Fila ÁREA -->
                        <tr class="rexp-row rexp-row--area" data-target="<%= aId %>" onclick="toggleRexp(this)">
                          <td class="rexp-toggle"><span class="rexp-arrow">▶</span></td>
                          <td>
                            <strong><%= area %></strong>
                            <% if (areaTotalRec > 0) { %>
                              <span class="dash-rec-badge" style="margin-left:.5rem;">
                                <span class="dash-rec-badge__dot"></span>
                                <%= areaTotalRec %> rec<% if (areaOkConRec > 0) { %> · <%= areaOkConRec %> OK<% } %>
                              </span>
                            <% } %>
                          </td>
                          <td style="text-align:right">
                            <span class="eff-badge eff-badge--<%= effClass(areaAvg) %>"><%= fmtEff(areaAvg) %></span>
                          </td>
                          <td class="td-hide-mobile">
                            <div class="slot-strip slot-strip--sm">
                              <% allSlots.forEach(s => { %>
                                <div class="slot-strip__seg slot-strip__seg--<%= effClass(s.eficienciaPct ?? s.eficiencia) %>"
                                  title="<%= s.slotHora %>:00 — <%= fmtEff(s.eficienciaPct ?? s.eficiencia) %>"></div>
                              <% }) %>
                            </div>
                          </td>
                        </tr>

                        <!-- Filas SUBTAREA -->
                        <% let subIdx = 0; Object.entries(subs).forEach(([sub, empMap]) => {
                             const subRecs = Object.values(empMap).flat();
                             const subAvg  = avgArr(subRecs.map(r => r.eficienciaPct ?? r.eficiencia ?? null));
                             const subSlots = subRecs.slice().sort((a,b) => (a.slotHora??0)-(b.slotHora??0));
                             const sId = aId + '-sub-' + subIdx++;
                             let subTotalRec = 0, subOkConRec = 0;
                             (asignaciones || []).forEach(a => {
                               if ((a.subtarea?.nombre || '') === sub && (a.area?.nombre || '') === area) {
                                 const rd = _rechByAsig[a.id] || {};
                                 subTotalRec += rd.totalRec || 0;
                                 subOkConRec += rd.okConRec || 0;
                               }
                             });
                        %>
                          <tr class="rexp-row rexp-row--sub rexp-child--<%= aId %>" style="display:none"
                              data-target="<%= sId %>" onclick="toggleRexp(this)">
                            <td class="rexp-toggle" style="padding-left:1.8rem">
                              <span class="rexp-arrow rexp-arrow--sm">▶</span>
                            </td>
                            <td style="padding-left:1.4rem;color:rgba(15,23,42,.72);font-size:.9rem">
                              <%= sub %>
                              <% if (subTotalRec > 0) { %>
                                <span class="dash-rec-badge" style="margin-left:.5rem;font-size:.72rem;">
                                  <span class="dash-rec-badge__dot"></span>
                                  <%= subTotalRec %> rec<% if (subOkConRec > 0) { %> · <%= subOkConRec %> OK<% } %>
                                </span>
                              <% } %>
                            </td>
                            <td style="text-align:right">
                              <span class="eff-badge eff-badge--<%= effClass(subAvg) %>" style="font-size:.78rem"><%= fmtEff(subAvg) %></span>
                            </td>
                            <td class="td-hide-mobile">
                              <div class="slot-strip slot-strip--sm">
                                <% subSlots.forEach(s => { %>
                                  <div class="slot-strip__seg slot-strip__seg--<%= effClass(s.eficienciaPct ?? s.eficiencia) %>"
                                    title="<%= s.slotHora %>:00 — <%= fmtEff(s.eficienciaPct ?? s.eficiencia) %>"></div>
                                <% }) %>
                              </div>
                            </td>
                          </tr>

                          <!-- Filas EMPLEADO -->
                          <% let empIdx = 0; Object.entries(empMap).forEach(([emp, empRecs]) => {
                               const empAvg   = avgArr(empRecs.map(r => r.eficienciaPct ?? r.eficiencia ?? null));
                               const empSlots = empRecs.slice().sort((a,b) => (a.slotHora??0)-(b.slotHora??0));
                               const eId = sId + '-emp-' + empIdx++;
                               const _asnEmp = (asignaciones || []).find(a =>
                                 (a.subtarea?.nombre || '') === sub &&
                                 (a.area?.nombre || '') === area &&
                                 ((a.empleado?.nombre || '') === emp || `${a.empleado?.nombre||''} ${a.empleado?.apellidos||''}`.trim() === emp)
                               );
                               const _empRd = _asnEmp ? (_rechByAsig[_asnEmp.id] || {}) : {};
                               const empTotalRec = _empRd.totalRec || 0;
                               const empOkConRec = _empRd.okConRec || 0;
                          %>
                            <tr class="rexp-row rexp-row--sub rexp-child--<%= sId %>" style="display:none"
                                data-target="<%= eId %>" onclick="toggleRexp(this)">
                              <td class="rexp-toggle" style="padding-left:3rem">
                                <span class="rexp-arrow rexp-arrow--sm">▶</span>
                              </td>
                              <td style="padding-left:2.6rem;font-size:.88rem;font-weight:700">
                                <%= emp %>
                                <% if (empTotalRec > 0) { %>
                                  <span class="dash-rec-badge" style="margin-left:.5rem;font-size:.72rem;">
                                    <span class="dash-rec-badge__dot"></span>
                                    <%= empTotalRec %> rec<% if (empOkConRec > 0) { %> · <%= empOkConRec %> OK<% } %>
                                  </span>
                                <% } %>
                              </td>
                              <td style="text-align:right">
                                <span class="eff-badge eff-badge--<%= effClass(empAvg) %>" style="font-size:.75rem"><%= fmtEff(empAvg) %></span>
                              </td>
                              <td class="td-hide-mobile">
                                <div class="slot-strip slot-strip--sm">
                                  <% empSlots.forEach(s => { %>
                                    <div class="slot-strip__seg slot-strip__seg--<%= effClass(s.eficienciaPct ?? s.eficiencia) %>"
                                      title="<%= s.slotHora %>:00 — <%= fmtEff(s.eficienciaPct ?? s.eficiencia) %>"></div>
                                  <% }) %>
                                </div>
                              </td>
                            </tr>

                            <!-- Filas SLOT -->
                            <% empRecs.sort((a,b) => (a.slotHora??0)-(b.slotHora??0)).forEach(r => { %>
                              <tr class="rexp-row rexp-row--slot rexp-child--<%= eId %>" style="display:none">
                                <td></td>
                                <td style="padding-left:4rem;font-size:.82rem;color:rgba(15,23,42,.60)">
                                  <%= r.slotHora %>:00
                                </td>
                                <td style="text-align:right">
                                  <span class="eff-badge eff-badge--<%= effClass(r.eficienciaPct ?? r.eficiencia) %>" style="font-size:.72rem">
                                    <%= fmtEff(r.eficienciaPct ?? r.eficiencia) %>
                                  </span>
                                </td>
                                <td class="td-hide-mobile" style="font-size:.78rem;color:rgba(15,23,42,.50)">
                                  <%= r.cantidad %> pzas / std <%= r.estandar %>
                                </td>
                              </tr>
                            <% }) %>

                          <% }) %>
                        <% }) %>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                  <div class="empty-state text-center py-4">
                    <i class="bi bi-inbox mb-3" style="font-size: 2.5rem; color: var(--dm-ink-soft); opacity: 0.5;"></i>
                    <p class="mb-4" style="color: var(--dm-ink-dim);">No hay capturas registradas hoy</p>
                    <a href="/encargado/captura" class="btn--success-alt">
                      <i class="bi bi-plus-circle me-2"></i> Registrar captura
                    </a>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <footer class="footer d-flex justify-content-between mt-5 pt-3">
          <span>© 2026 MERO. Todos los derechos reservados.</span>
          <span>Versión 1.0.0</span>
        </footer>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script>
    // Init: convierte style="display:none" a clase para evitar override de CSS mobile
    document.querySelectorAll('[class*="rexp-child--"]').forEach(function(r) {
      r.classList.add('rexp-hidden');
      r.style.display = '';
    });

    function toggleRexp(row) {
      const target = row.dataset.target;
      if (!target) return;

      const children = document.querySelectorAll('.rexp-child--' + target);
      const arrow    = row.querySelector('.rexp-arrow');
      const isOpen   = row.classList.contains('rexp-row--open');

      if (isOpen) {
        collapseAll(target);
        row.classList.remove('rexp-row--open');
        if (arrow) arrow.textContent = '▶';
      } else {
        children.forEach(c => { c.classList.remove('rexp-hidden'); });
        row.classList.add('rexp-row--open');
        if (arrow) arrow.textContent = '▼';
      }
    }

    function collapseAll(target) {
      const children = document.querySelectorAll('.rexp-child--' + target);
      children.forEach(c => {
        c.classList.add('rexp-hidden');
        c.classList.remove('rexp-row--open');
        const arrow = c.querySelector('.rexp-arrow');
        if (arrow) arrow.textContent = '▶';
        const subTarget = c.dataset.target;
        if (subTarget) collapseAll(subTarget);
      });
    }
  </script>
</body>
</html>