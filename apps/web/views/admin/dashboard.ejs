<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/cards.css">
  <link rel="stylesheet" href="/css/ui.css">
  <link rel="stylesheet" href="/css/buttons.css">
  <link rel="stylesheet" href="/css/dark.css">
</head>

<body>
  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <nav class="navbar">
        <button class="btn-icon" id="sidebarToggle" title="Menú">
          <i class="bi bi-list"></i>
        </button>
        <h1 class="page-title">Panel Administrador</h1>
        
        <div class="ms-auto">
          <div class="user-dropdown" id="userDropdown">
            <div class="user-dropdown-toggle" onclick="toggleUserMenu()">
              <div class="user-avatar"><span>A</span></div>
              <span class="user-name d-none d-md-inline">Administrador</span>
              <i class="bi bi-chevron-down" style="color: #94a3b8; font-size: 0.8rem;"></i>
            </div>
            
            <div class="dropdown-menu" id="userMenu">
              <div class="dropdown-header">
                <strong>Administrador</strong>
                <small>admin@mero.com</small>
              </div>
              <div class="dropdown-divider"></div>
              <a href="/auth/logout" class="dropdown-item text-danger">
                <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
              </a>
            </div>
          </div>
        </div>
      </nav>

      <main class="content-wrapper">
        <%- include('../partials/flash') %>

        <%
          const totalAsignados = (asignaciones || []).length;
          let sumEff = 0, countEff = 0;
          (metricas || []).forEach(m => {
            if (m.eficienciaPct != null) { sumEff += Number(m.eficienciaPct); countEff++; }
          });
          const avgEff = countEff ? (sumEff / countEff) : null;
          const okCount = (metricas || []).filter(m => m.eficienciaPct >= 90).length;
          const warnCount = (metricas || []).filter(m => m.eficienciaPct >= 70 && m.eficienciaPct < 90).length;
          const failCount = (metricas || []).filter(m => m.eficienciaPct > 0 && m.eficienciaPct < 70).length;

          const areasActivas = [...new Set(
            (metricas || []).map(m =>
              m.areaNombre ||
              m.area?.nombre ||
              (typeof m.area === 'string' ? m.area : null) ||
              'Área'
            )
          )].length;
          
          const hoy = new Date().toLocaleDateString('es-MX', { 
            weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
          });
        %>

        <div class="welcome-header d-flex justify-content-between align-items-start mb-4">
          <div>
            <h2 style="font-weight: 800; font-size: 1.8rem;">¡Bienvenido, Administrador!</h2>
            <p>Panel de control MERO - Métricas y Eficiencia Operativa</p>
          </div>
          <div class="date-badge">
            <i class="bi bi-calendar3 me-2"></i><%= hoy %>
          </div>
        </div>

        <div class="grid-stats--metrics mb-4">
          <div class="stat-card--gradient stat-card--blue">
            <div class="stat-card__label">Empleados Activos</div>
            <div class="stat-card__value"><%= totalAsignados %></div>
            <div class="stat-card__sub">En planta ahora</div>
          </div>

          <div class="stat-card--gradient stat-card--green">
            <div class="stat-card__label">Eficiencia Promedio</div>
            <div class="stat-card__value"><%= avgEff ? avgEff.toFixed(0) + '%' : '0%' %></div>
            <div class="stat-card__sub">Todos los slots de hoy</div>
          </div>

          <div class="stat-card--gradient stat-card--indigo">
            <div class="stat-card__label">Slots en Verde</div>
            <div class="stat-card__value"><%= okCount %></div>
            <div class="stat-card__sub">Eficiencia > 90%</div>
          </div>

          <div class="stat-card--gradient stat-card--orange">
            <div class="stat-card__label">Áreas Activas</div>
            <div class="stat-card__value"><%= areasActivas %></div>
            <div class="stat-card__sub">Con registro hoy</div>
          </div>
        </div>

        <div class="card mb-4" style="border-radius: 18px;">
          <div class="card-body py-2">
            <div class="d-flex align-items-center gap-3 flex-wrap">
              <span class="badge-summary">
                <i class="bi bi-circle-fill text-success" style="font-size: 0.6rem;"></i> Verde (≥90%): <%= okCount %>
              </span>
              <span class="badge-summary">
                <i class="bi bi-circle-fill text-warning" style="font-size: 0.6rem;"></i> Riesgo (70-89%): <%= warnCount %>
              </span>
              <span class="badge-summary">
                <i class="bi bi-circle-fill text-danger" style="font-size: 0.6rem;"></i> Crítico (&lt;70%): <%= failCount %>
              </span>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-12 col-lg-3">
            <div class="card h-100">
              <div class="card-header bg-transparent border-bottom-0 pb-0">
                <h5 class="card-title"><i class="bi bi-lightning-charge me-2" style="color: #f59e0b;"></i> Acciones Rápidas</h5>
              </div>
              <div class="card-body d-grid gap-2">
                <a href="/admin/usuarios" class="quick-btn is-blue"><i class="bi bi-people"></i> Usuarios</a>
                <a href="/encargado/captura" class="quick-btn is-green"><i class="bi bi-clipboard-check"></i> Registrar Captura</a>
                <a href="/admin/catalogos/areas" class="quick-btn is-cyan"><i class="bi bi-diagram-3"></i> Nueva Área</a>
                <a href="/admin/catalogos/subtareas" class="quick-btn is-amber"><i class="bi bi-list-check"></i> Nueva Subárea</a>
                <a href="/consultor/historico" class="quick-btn is-gray"><i class="bi bi-bar-chart"></i> Ver Reportes</a>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-9">
            <div class="card h-100">
              <div class="card-header card-header--eficiencia bg-transparent border-bottom-0 pb-0">
                <h5 class="card-title mb-0">
                  <i class="bi bi-bar-chart-line me-2" style="color: #3b82f6;"></i>
                  Eficiencia por área
                </h5>
                <a href="/consultor" class="btn--manage" style="font-size: 0.75rem;">Ver métricas →</a>
              </div>

              <% if ((metricas || []).length > 0) { %>
                <%
                  function getAreaName(m) {
                    return (
                      m?.areaNombre ||
                      m?.area?.nombre ||
                      (typeof m?.area === 'string' ? m.area : null) ||
                      'Área'
                    );
                  }

                  function getEff(m) {
                    const v = m?.eficienciaPct ?? m?.eficiencia ?? null;
                    if (v == null) return null;

                    const n = Number(v);
                    if (!Number.isFinite(n)) return null;

                    return n;
                  }

                  function getSlotHora(m) {
                    return m?.slotHora ?? m?.slot ?? m?.hora ?? null;
                  }

                  function slotClass(val) {
                    if (val == null) return 'none';
                    if (val >= 90) return 'ok';
                    if (val >= 70) return 'warn';
                    return 'fail';
                  }

                  function fmtEff(val) {
                    if (val == null || !Number.isFinite(Number(val))) return '—';
                    return Number(val).toFixed(1) + '%';
                  }

                  const byArea = {};

                  (metricas || []).forEach(m => {
                    const key = getAreaName(m);
                    if (!byArea[key]) byArea[key] = [];
                    byArea[key].push(m);
                  });

                  Object.values(byArea).forEach(arr => {
                    arr.sort((a, b) => Number(getSlotHora(a) ?? 0) - Number(getSlotHora(b) ?? 0));
                  });
                %>

                <div class="card-body">
                  <div style="padding: 0;">
                    <% Object.entries(byArea).forEach(([area, slots]) => {
                        let areaSum = 0, areaCount = 0;

                        slots.forEach(s => {
                          const e = getEff(s);
                          if (e != null) {
                            areaSum += e;
                            areaCount++;
                          }
                        });

                        const areaAvg = areaCount ? (areaSum / areaCount) : null;
                    %>
                      <div class="slot-area">
                        <div class="slot-area__header">
                          <span class="slot-area__name"><%= area %></span>
                          <span class="eff-value <%= slotClass(areaAvg) %>"><%= fmtEff(areaAvg) %></span>
                        </div>

                        <div class="slot-strip slot-strip--lg">
                          <% slots.forEach(s => { %>
                            <div
                              class="slot-strip__seg slot-strip__seg--<%= slotClass(getEff(s)) %>"
                              title="<%= (getSlotHora(s) != null ? getSlotHora(s) + ':00' : 'Sin hora') %> — <%= fmtEff(getEff(s)) %>">
                            </div>
                          <% }) %>
                        </div>

                        <div class="slot-area__hours">
                          <% slots.forEach(s => { %>
                            <span class="slot-area__hour"><%= getSlotHora(s) %>h</span>
                          <% }) %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% } else { %>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                  <div class="empty-state text-center py-4">
                    <i class="bi bi-inbox mb-3" style="font-size: 2.5rem; color: var(--dm-ink-soft); opacity: 0.5;"></i>
                    <p class="mb-4" style="color: var(--dm-ink-dim);">No hay capturas registradas hoy</p>
                    <a href="/encargado/captura" class="btn--success-alt">
                      <i class="bi bi-plus-circle me-2"></i> Registrar captura
                    </a>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

        <footer class="footer d-flex justify-content-between mt-5 pt-3">
          <span>© 2026 MERO. Todos los derechos reservados.</span>
          <span>Versión 1.0.0</span>
        </footer>
      </main>
    </div>
  </div>

  <script src="/js/main.js"></script>

</body>
</html>