<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/icons') %>
  <%- include('../partials/nav') %>

  <div class="page page--admin">
    <div class="container">

      <div class="page-header">
        <div>
          <h1>Panel Administrador</h1>
          <p class="page-header__sub">
            <h4><svg class="icon"><use href="#icon-clock"/></svg>
            <%= hoy %></h4>
          </p>
        </div>
      </div>

      <%- include('../partials/flash') %>

      <%
        const totalAsignados = asignaciones.length;
        let sumEff = 0, countEff = 0;
        metricas.forEach(m => {
          if (m.eficiencia != null) { sumEff += Number(m.eficiencia); countEff++; }
        });
        const avgEff = countEff ? (sumEff / countEff) : null;
        const okCount   = metricas.filter(m => m.eficiencia >= 90).length;
        const warnCount = metricas.filter(m => m.eficiencia >= 70 && m.eficiencia < 90).length;
        const failCount = metricas.filter(m => m.eficiencia > 0  && m.eficiencia < 70).length;
      %>

      <div class="grid-stats page--encargado">
      <div class="stat-card stat-card--empleados">
        <div class="stat-card__label">Empleados activos</div>
          <div class="stat-card__value"><%= totalAsignados %></div>
          <div class="stat-card__sub">en planta ahora</div>
        </div>
        <div class="stat-card stat-card--eficiencia">
          <div class="stat-card__label">Eficiencia promedio</div>
          <div class="stat-card__value"><%= fmtEff(avgEff) %></div>
          <div class="stat-card__sub">todos los slots de hoy</div>
        </div>
       <div class="stat-card stat-card--registros">
          <div class="stat-card__label">Slots en verde</div>
          <div class="stat-card__value"><%= okCount %></div>
          <div class="stat-card__sub">eficiencia >= 90%</div>
        </div>
        <div class="stat-card stat-card--riesgo">
          <div class="stat-card__label">Slots en riesgo</div>
          <div class="stat-card__value"><%= warnCount %></div>
          <div class="stat-card__sub">eficiencia 70-89%</div>
        </div>
        <div class="stat-card stat-card--criticos">
          <div class="stat-card__label">Slots criticos</div>
          <div class="stat-card__value"><%= failCount %></div>
          <div class="stat-card__sub">eficiencia < 70%</div>
        </div>
      </div>

      <% if (metricas.length > 0) { %>
        <%
          const byArea = {};
          metricas.forEach(m => {
            if (!byArea[m.areaNombre]) byArea[m.areaNombre] = [];
            byArea[m.areaNombre].push(m);
          });
        %>
        <div class="card" style="margin-bottom:var(--gap-lg)">
          <div class="card__header">
            <span class="card__title">Eficiencia por slot y area -- hoy</span>
            <a href="/consultor" class="btn btn--ghost btn--sm">
              <svg class="icon"><use href="#icon-chart"/></svg>
              Ver metricas
            </a>
          </div>
          <% Object.entries(byArea).forEach(([area, slots]) => { %>
            <div class="slot-area">
              <div class="slot-area__header">
                <span class="slot-area__name"><%= area %></span>
                <% const last = slots[slots.length - 1]; %>
                <span class="eff-value <%= effClass(last?.eficiencia) %>">
                  <%= fmtEff(last?.eficiencia) %>
                </span>
              </div>
              <div class="slot-strip slot-strip--lg">
                <% slots.forEach(s => { %>
                  <div class="slot-strip__seg slot-strip__seg--<%= slotClass(s.eficiencia) %>"
                       title="<%= s.slotHora %>h -- <%= fmtEff(s.eficiencia) %>"></div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <div class="grid-3" style="margin-top:var(--gap)">
        <a href="/admin/usuarios" class="quick-link">
          <div class="quick-link__icon">
            <svg class="icon"><use href="#icon-users"/></svg>
          </div>
          <div>
            <div class="quick-link__title">Usuarios</div>
            <div class="quick-link__desc">Gestionar accesos</div>
          </div>
        </a>
        <a href="/admin/catalogos/areas" class="quick-link">
          <div class="quick-link__icon">
            <svg class="icon"><use href="#icon-catalog"/></svg>
          </div>
          <div>
            <div class="quick-link__title">Catalogos</div>
            <div class="quick-link__desc">Areas, subtareas, modelos</div>
          </div>
        </a>
        <a href="/admin/auditoria" class="quick-link">
          <div class="quick-link__icon">
            <svg class="icon"><use href="#icon-audit"/></svg>
          </div>
          <div>
            <div class="quick-link__title">Auditoria</div>
            <div class="quick-link__desc">Log de cambios</div>
          </div>
        </a>
      </div>
    </div>
  </div>
</body>
</html>
