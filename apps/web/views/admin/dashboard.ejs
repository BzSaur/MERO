<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  
  <!-- Asegurar Google Fonts Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="wrapper">
    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <!-- Navbar con botón de cerrar sesión funcional -->
      <nav class="navbar">
        <button class="btn-icon" id="sidebarToggle" title="Menú">
          <i class="bi bi-list"></i>
        </button>
        
        <h1 class="page-title">Panel Administrador</h1>
        
        <div class="ms-auto">
          <!-- User Dropdown (solo cerrar sesión) -->
          <div class="user-dropdown" id="userDropdown">
            <div class="user-dropdown-toggle" onclick="toggleUserMenu()">
              <div class="user-avatar">
                <span>A</span>
              </div>
              <span class="user-name d-none d-md-inline">Administrador</span>
              <i class="bi bi-chevron-down" style="color: #94a3b8; font-size: 0.8rem;"></i>
            </div>
            
            <!-- Dropdown menu -->
            <div class="dropdown-menu" id="userMenu">
              <div class="dropdown-header">
                <strong>Administrador</strong>
                <small>admin@mero.com</small>
              </div>
              <div class="dropdown-divider"></div>
              <a href="/auth/logout" class="dropdown-item text-danger" onclick="handleLogout(event)">
                <i class="bi bi-box-arrow-right"></i>
                Cerrar Sesión
              </a>
            </div>
          </div>
        </div>
      </nav>

      <main class="content-wrapper">
        <%- include('../partials/flash') %>

        <%
          // Cálculo de variables
          const totalAsignados = (asignaciones || []).length;

          let sumEff = 0, countEff = 0;
          (metricas || []).forEach(m => {
            if (m.eficiencia != null) { 
              sumEff += Number(m.eficiencia); 
              countEff++; 
            }
          });
          const avgEff = countEff ? (sumEff / countEff) : null;

          const okCount   = (metricas || []).filter(m => m.eficiencia >= 90).length;
          const warnCount = (metricas || []).filter(m => m.eficiencia >= 70 && m.eficiencia < 90).length;
          const failCount = (metricas || []).filter(m => m.eficiencia > 0  && m.eficiencia < 70).length;

          // Agrupar por área
          const metricasHoy = metricas || [];
          const byArea = {};
          const areasList = [];
          
          metricasHoy.forEach(m => {
            const k = m.areaNombre || 'Sin área';
            if (!byArea[k]) {
              byArea[k] = [];
              areasList.push(k);
            }
            byArea[k].push(m);
          });

          // Lista de áreas activas
          const areasActivas = areasList.length ? areasList : [
            'Administración', 'Sistemas', 'Laboratorio', 'Producción', 
            'Calidad', 'Mantenimiento', 'Almacén', 'Compras', 'Ventas',
            'RH', 'Finanzas', 'Marketing', 'I+D', 'Logística', 'Servicio'
          ];
          
          const areasCount = areasActivas.length;

          const hoy = new Date().toLocaleDateString('es-MX', { 
            weekday: 'long', 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          });
        %>
        ___//hola

        <!-- Welcome Header -->
        <div class="welcome-header d-flex justify-content-between align-items-start">
          <div>
            <h2>¡Bienvenido, Administrador!</h2>
            <p>Panel de control MERO - Métricas y Eficiencia Operativa</p>
          </div>
          <div class="date-badge">
            <i class="bi bi-calendar3 me-1"></i>
            <%= hoy %>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="row g-2 mb-3">
          <div class="col-6 col-lg-3">
            <div class="stat-card">
              <div class="card-body">
                <div class="stat-label">EMPLEADOS ACTIVOS</div>
                <div class="stat-value"><%= totalAsignados %></div>
                <div class="stat-sub">En planta ahora</div>
              </div>
            </div>
          </div>

          <div class="col-6 col-lg-3">
            <div class="stat-card">
              <div class="card-body">
                <div class="stat-label">EFICIENCIA PROMEDIO</div>
                <div class="stat-value"><%= avgEff ? avgEff.toFixed(1) + '%' : '0%' %></div>
                <div class="stat-sub">Todos los slots de hoy</div>
              </div>
            </div>
          </div>

          <div class="col-6 col-lg-3">
            <div class="stat-card">
              <div class="card-body">
                <div class="stat-label">SLOTS EN VERDE</div>
                <div class="stat-value"><%= okCount %></div>
                <div class="stat-sub">Eficiencia > 90%</div>
              </div>
            </div>
          </div>

          <div class="col-6 col-lg-3">
            <div class="stat-card">
              <div class="card-body">
                <div class="stat-label">ÁREAS ACTIVAS</div>
                <div class="stat-value"><%= areasCount %></div>
                <div class="stat-sub">Con registro hoy</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Resumen de slots -->
        <div class="row g-2 mb-3">
          <div class="col-12">
            <div class="card">
              <div class="card-body">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                  <span class="badge-summary">
                    <i class="bi bi-check-circle-fill text-success"></i>
                    Verde (≥90%): <%= okCount %>
                  </span>
                  <span class="badge-summary">
                    <i class="bi bi-exclamation-triangle-fill text-warning"></i>
                    Riesgo (70-89%): <%= warnCount %>
                  </span>
                  <span class="badge-summary">
                    <i class="bi bi-x-circle-fill text-danger"></i>
                    Crítico (&lt;70%): <%= failCount %>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Grid -->
        <div class="row g-3">
          <!-- Quick Actions -->
          <div class="col-12 col-lg-3">
            <div class="card">
              <div class="card-header">
                <h5 class="card-title">
                  <i class="bi bi-lightning-charge me-2" style="color: #f59e0b;"></i>
                  Acciones Rápidas
                </h5>
              </div>
              <div class="card-body d-grid gap-2">
                <a href="/admin/usuarios" class="btn-outline-primary">
                  <i class="bi bi-people me-2"></i> Usuarios
                </a>
                <a href="/encargado/captura" class="btn-outline-primary">
                  <i class="bi bi-clipboard-check me-2"></i> Registrar Captura
                </a>
                <a href="/admin/catalogos/areas" class="btn-outline-primary">
                  <i class="bi bi-diagram-3 me-2"></i> Nueva Área
                </a>
                <a href="/admin/catalogos/subtareas" class="btn-outline-primary">
                  <i class="bi bi-list-check me-2"></i> Nueva Subárea
                </a>
                <a href="/consultor/historico" class="btn-outline-primary">
                  <i class="bi bi-bar-chart me-2"></i> Ver Reportes
                </a>
              </div>
            </div>
          </div>

          <!-- Eficiencia por área -->
          <div class="col-12 col-lg-5">
            <div class="card">
              <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                  <i class="bi bi-bar-chart-line me-2" style="color: #3b82f6;"></i>
                  Eficiencia por área
                </h5>
                <a href="/consultor" style="color: #3b82f6; font-weight: 500; font-size: 0.75rem; text-decoration: none;">
                  Ver métricas <i class="bi bi-arrow-right ms-1"></i>
                </a>
              </div>

              <div class="card-body">
                <% if (!metricasHoy.length) { %>
                  <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <p>No hay capturas registradas hoy</p>
                    <a href="/encargado/captura" class="btn">
                      <i class="bi bi-plus-circle me-2"></i>
                      Registrar captura
                    </a>
                  </div>
                <% } else { %>
                  <div class="d-flex flex-column gap-3">
                    <% Object.entries(byArea).forEach(([area, slots]) => { %>
                      <!-- Aquí iría el código de los slots -->
                    <% }) %>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Áreas Activas -->
          <div class="col-12 col-lg-4">
            <div class="card">
              <div class="card-header">
                <h5 class="card-title">
                  <i class="bi bi-diagram-3 me-2" style="color: #10b981;"></i>
                  Áreas Activas
                </h5>
              </div>
              <div class="card-body">
                <div class="areas-grid">
                  <% areasActivas.slice(0, 15).forEach(area => { %>
                    <div class="area-item">
                      <i class="bi bi-folder"></i>
                      <%= area %>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <footer class="footer d-flex justify-content-between">
          <span>© 2026 MERO. Todos los derechos reservados.</span>
          <span>Versión 1.0.0</span>
        </footer>
      </main>
    </div>
  </div>

  <script src="/js/nav.js"></script>
</body>
</html>