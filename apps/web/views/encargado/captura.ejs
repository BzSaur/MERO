<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <div class="page page--captura page--auditoria page--asignar page--areas">
          <div class="container">

            <div class="page-header page-header--auditoria">
              <div>
                <h1>Registrar Captura</h1>
                <p class="page-header__sub">Ingresa la producción por slot horario</p>
              </div>

              <a href="/encargado" class="btn btn--back">
                <svg class="icon"><use href="#icon-back"/></svg>
                Volver
              </a>
            </div>

            <%
              const _asignaciones = Array.isArray(asignaciones) ? asignaciones : [];
              const _slotsDisponibles = Array.isArray(slotsDisponibles) ? slotsDisponibles : [];
            %>

            <div class="card card--asignar card--asignar-act card--usuarios">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Nueva captura</span></h3>
                <span class="badge badge--ok"><%= _asignaciones.length %></span>
              </div>

              <% if (!_asignaciones.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin asignaciones activas.</p>
                  <p class="empty__sub">Primero asigna un usuario a un área para registrar su captura.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Usuario</th>
                        <th>Área</th>
                        <th>Horario</th>
                        <th>Cantidad</th>
                        <th>Capturar</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% _asignaciones.forEach((a, idx) => { 
                           const formId = `capturaForm_${a.id}_${idx}`;
                      %>
                        <tr>
                          <td>
                            <%= a.empleado?.nombre %> <%= a.empleado?.apellidos || '' %>
                          </td>

                          <td>
                            <%= a.area?.nombre || '—' %>
                          </td>

                          <td>
                            <select
                              class="form-control"
                              name="slotHora"
                              form="<%= formId %>"
                              required
                              <%= !_slotsDisponibles.length ? 'disabled' : '' %>
                            >
                              <option value="">— Seleccionar —</option>
                              <% _slotsDisponibles.forEach(s => { %>
                                <option value="<%= s.hora %>"><%= s.label %></option>
                              <% }) %>
                            </select>
                          </td>

                          <td>
                            <input
                              class="form-control"
                              type="number"
                              name="cantidad"
                              form="<%= formId %>"
                              min="0"
                              required
                              placeholder="0"
                              <%= !_slotsDisponibles.length ? 'disabled' : '' %>
                            >
                          </td>

                          <td>
                            <button
                              type="submit"
                              form="<%= formId %>"
                              class="btn btn--edit btn--sm"
                              <%= !_slotsDisponibles.length ? 'disabled' : '' %>
                            >
                              <svg class="icon"><use href="#icon-check"/></svg>
                              Capturar
                            </button>

                            <form
                              id="<%= formId %>"
                              method="POST"
                              action="/encargado/captura"
                              class="js-form-captura"
                              style="display:none;"
                            >
                              <input type="hidden" name="asignacionId" value="<%= a.id %>">
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>

                <% if (!_slotsDisponibles.length) { %>
                  <div class="empty empty--asignar" style="padding-top: 0;">
                    <p class="empty__sub">
                      En este momento no hay slots disponibles para captura.
                    </p>
                  </div>
                <% } %>
              <% } %>
            </div>

            <div class="card card--asignar card--asignar-act card--usuarios">
              <div class="card__header card__header--split">
                <div class="card__header-left">
                  <h3><span class="card__title">Asignaciones activas</span></h3>
                  <span class="badge badge--ok"><%= _asignaciones.length %></span>
                </div>

                <a href="/encargado/asignar" class="btn btn--success btn--sm">
                  Gestionar asignaciones
                </a>
              </div>

              <% if (!_asignaciones.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin asignaciones activas.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Usuario</th>
                        <th>Área</th>
                        <th class="td-hide-mobile">Subtarea</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% _asignaciones.forEach(a => { %>
                        <tr>
                          <td><%= a.empleado?.nombre %> <%= a.empleado?.apellidos || '' %></td>
                          <td><%= a.area?.nombre || '—' %></td>
                          <td class="td-hide-mobile"><%= a.subtarea?.nombre || '—' %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>

  <script src="/js/main.js"></script>
  <script src="/js/alerts.js" defer></script>

  <script>
    (() => {
      const SwalRef = window.Swal;
      const KEY_CAPTURA_OK = 'mero_captura_ok';

      function showPendingAlerts() {
        if (!SwalRef) return;

        const capturaOk = sessionStorage.getItem(KEY_CAPTURA_OK);

        if (capturaOk === '1') {
          sessionStorage.removeItem(KEY_CAPTURA_OK);

          SwalRef.fire({
            icon: 'success',
            title: 'Captura realizada exitosamente',
            confirmButtonText: 'Aceptar'
          });
        }
      }

      document.addEventListener('DOMContentLoaded', showPendingAlerts);

      document.querySelectorAll('.js-form-captura').forEach((form) => {
        form.addEventListener('submit', (e) => {
          const formId = form.id;
          const slot = document.querySelector(`[name="slotHora"][form="${formId}"]`);
          const cantidad = document.querySelector(`[name="cantidad"][form="${formId}"]`);

          if (!slot?.value || !cantidad?.value) {
            e.preventDefault();

            if (SwalRef) {
              SwalRef.fire({
                icon: 'warning',
                title: 'Faltan datos',
                text: 'Selecciona un horario y captura la cantidad antes de guardar.',
                confirmButtonText: 'Aceptar'
              });
            }

            return;
          }

          sessionStorage.setItem(KEY_CAPTURA_OK, '1');
        });
      });
    })();
  </script>
</body>
</html>