<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <div class="page page--captura">
          <div class="container">
            <div class="page-header">
              <div>
                <h1>Ingresa la producción por slot horario</h1>
              </div>
            </div>

            <%
              const _asignaciones = Array.isArray(asignaciones) ? asignaciones : [];
              const _slots = [8,9,10,11,12,13,15,16,17,18];
            %>

            <div class="card card--captura" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Nueva captura</span></h3>
                <span class="badge badge--ok"><%= _asignaciones.length %></span>
              </div>

              <form method="POST" action="/encargado/captura" class="form-grid" style="padding: var(--gap) var(--gap-lg);">
                <div class="form-group">
                  <label class="form-label" for="asignacionId">Asignación activa</label>
                  <select class="form-control" id="asignacionId" name="asignacionId" required>
                    <option value="">— Seleccionar —</option>
                    <% (asignaciones || []).forEach(a => { %>
                      <option value="<%= a.id %>">
                        <%= a.empleado?.nombre %> <%= a.empleado?.apellidos || '' %> —
                        <%= a.area?.nombre || 'Sin área' %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="form-group">
                  <label class="form-label" for="slotHora">Slot horario</label>
                  <select
                    class="form-control"
                    id="slotHora"
                    name="slotHora"
                    required
                    <%= !slotsDisponibles || !slotsDisponibles.length ? 'disabled' : '' %>
                  >
                    <% if (slotsDisponibles && slotsDisponibles.length) { %>
                      <% slotsDisponibles.forEach(s => { %>
                        <option value="<%= s.hora %>" selected><%= s.label %></option>
                      <% }) %>
                    <% } else { %>
                      <option value="">No hay slot activo disponible en este momento</option>
                    <% } %>
                  </select>

                  <% if (!slotsDisponibles || !slotsDisponibles.length) { %>
                    <small style="display:block; margin-top:8px; color:#b45309;">
                      Solo se puede capturar en el slot horario que está transcurriendo actualmente.
                    </small>
                  <% } %>
                </div>

                <div class="form-group">
                  <label class="form-label" for="cantidad">Cantidad producida</label>
                  <input class="form-control" type="number" id="cantidad" name="cantidad" min="0" required>
                </div>

                <div class="form-group" style="align-self:end;">
                  <button
                    type="submit"
                    class="btn btn--success"
                    <%= !slotsDisponibles || !slotsDisponibles.length ? 'disabled' : '' %>
                  >
                    Registrar
                  </button>
                </div>
              <% } %>
            </div>

            <div class="card card--captura">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Asignaciones activas</span></h3>
                <span class="badge badge--ok"><%= (asignaciones || []).length %></span>
              </div>

              <% if (!asignaciones || !asignaciones.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin asignaciones activas.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean">
                    <thead>
                      <tr>
                        <th>Usuario</th>
                        <th>Área</th>
                        <th>Subtarea</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% (asignaciones || []).forEach(a => { %>
                        <tr>
                          <td><%= a.empleado?.nombre %> <%= a.empleado?.apellidos || '' %></td>
                          <td><%= a.area?.nombre || '—' %></td>
                          <td><%= a.subtarea?.nombre || '—' %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
</body>
</html>