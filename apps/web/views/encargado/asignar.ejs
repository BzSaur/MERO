<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <div class="page page--asignar page--auditoria page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Asignaciones</h1>
                <p class="page-header__sub">Escanea el QR del empleado para asignarlo a un área</p>
              </div>

              <a href="/encargado" class="btn btn--back">
                <svg class="icon"><use href="#icon-back"/></svg>
                Volver
              </a>
            </div>
            <% if (flash.error && flash.error.length) { %>
              <ul class="flash-list">
                <% flash.error.forEach(msg => { %><li class="flash flash--error"><%= msg %></li><% }) %>
              </ul>
            <% } %>
            <% if (flash.success && flash.success.length) { %>
              <script>
                document.addEventListener('DOMContentLoaded', function () {
                  Swal.fire({
                    icon: 'success',
                    title: 'Cambios guardados',
                    text: '<%= flash.success[0] %>',
                    confirmButtonText: 'Entendido',
                    confirmButtonColor: '#4f46e5'
                  });
                });
              </script>
            <% } %>

            <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
              <div class="card__header">
                <h3><span class="card__title">Escanear QR</span></h3>
              </div>

              <form method="POST" action="/encargado/asignar/scan-unified" id="formAsignar">
                <input type="hidden" id="tipoAsignacion" name="tipo" value="DIRECTA">
                <input type="hidden" id="actividadIndirectaId" name="actividadIndirectaId" value="">

                <div class="form-row users-controls users-controls--light" style="margin:0; padding: var(--gap) var(--gap-lg);">
                  <div class="users-controls__left">

                    <div class="form-group users-controls__field">
                      <label class="form-label" for="uuidQr">UUID del empleado</label>
                      <input
                        class="form-control mono"
                        type="text"
                        id="uuidQr"
                        name="uuidQr"
                        placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                        required
                        autofocus
                      >
                    </div>

                    <div class="form-group users-controls__field" id="fieldBuscarNombre" style="display:none; position:relative;">
                      <label class="form-label" for="buscarNombre">Nombre del empleado</label>
                      <input
                        class="form-control"
                        type="text"
                        id="buscarNombre"
                        placeholder="Buscar nombre..."
                        autocomplete="off"
                      >
                      <ul id="empleadoDropdown" style="display:none; position:absolute; z-index:1000; top:100%; left:0; right:0; margin:4px 0 0; padding:4px 0; list-style:none; background:#fff; border:1px solid rgba(30,58,138,.22); border-radius:14px; max-height:260px; overflow-y:auto; box-shadow:0 8px 24px rgba(0,0,0,.12);"></ul>
                    </div>

                    <div class="form-group users-controls__field users-controls__field--wide">
                      <label class="form-label" for="areaId">Área destino</label>

                      <% if (lockArea && areaFija) { %>
                        <input
                          class="form-control"
                          type="text"
                          value="<%= areaFija.nombre %>"
                          readonly
                        >
                        <input type="hidden" id="areaId" name="areaId" value="<%= areaFija.id %>">
                      <% } else { %>
                        <select class="form-control" id="areaId" name="areaId" required>
                          <option value="">— Seleccionar área —</option>
                          <% (areas || []).forEach(a => { %>
                            <option value="<%= a.id %>"><%= a.nombre %></option>
                          <% }) %>
                        </select>
                      <% } %>
                    </div>

                    <div class="form-group users-controls__field users-controls__field--wide">
                      <label class="form-label" for="subtareaSelect">
                        Subtarea / Actividad
                      </label>
                      <select class="form-control" id="subtareaSelect" required>
                        <option value="">— Seleccionar —</option>
                        <% if ((subtareas || []).length > 0) { %>
                          <optgroup label="Subtareas directas">
                            <% (subtareas || []).forEach(s => { %>
                              <option
                                value="directa-<%= s.id %>"
                                data-tipo="DIRECTA"
                                data-subtarea-id="<%= s.id %>"
                                data-area="<%= s.areaId %>">
                                <%= s.nombre %>
                              </option>
                            <% }) %>
                          </optgroup>
                        <% } %>
                        <% if ((actividadesIndirectas || []).length > 0) { %>
                          <optgroup label="Actividades indirectas">
                            <% (actividadesIndirectas || []).forEach(a => { %>
                              <option
                                value="indirecta-<%= a.id %>"
                                data-tipo="INDIRECTA"
                                data-actividad-id="<%= a.id %>">
                                <%= a.nombre %>
                              </option>
                            <% }) %>
                          </optgroup>
                        <% } %>
                      </select>
                      <input type="hidden" id="subtareaId" name="subtareaId" value="">
                    </div>

                    <div class="form-group users-controls__field users-controls__field--wide" id="fieldModelo">
                      <label class="form-label" for="modeloId">Modelo</label>
                      <select class="form-control" id="modeloId" name="modeloId" required>
                        <option value="">— Seleccionar modelo —</option>
                        <% (modelos || []).forEach(m => { %>
                          <option value="<%= m.id %>"><%= m.nombreSku || m.nombre || m.id %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="form-group users-controls__actions">
                      <button type="submit" class="btn btn--edit" id="btnAsignar">
                        <svg class="icon"><use href="#icon-qr"/></svg>
                        <span id="btnAsignarLabel">Asignar</span>
                      </button>

                      <button type="button" class="btn btn--ghost" id="btnScanCam">
                        <span></span><small>Escanear UUID con cámara</small>
                      </button>

                      <button type="button" class="btn btn--ghost" id="btnBuscarNombre">
                        <small>Buscar por nombre</small>
                      </button>
                    </div>

                  </div>
                </div>
              </form>
            </div>

            <div id="qrModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.6); place-items:center; z-index:9999;">
              <div style="background:#fff; padding:16px; border-radius:12px; width:min(640px, 92vw);">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <strong>Escanear QR</strong>
                  <button type="button" class="btn btn--ghost" id="btnCloseQr">Cerrar</button>
                </div>
                <video id="qrVideo" style="width:100%; margin-top:12px;" playsinline></video>
              </div>
            </div>

            <div class="card card--asignar card--asignar-act">
              <div class="card__header card__header--usuarios">
                <h3><span class="card__title">Activas ahora</span></h3>
                <span class="badge badge--ok"><%= (asignaciones || []).length %></span>
              </div>

              <% if (!asignaciones.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin asignaciones activas.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--blue">
                  <table class="table table--asignar table--blue">
                    <thead>
                      <tr>
                        <th>Empleado</th>
                        <th>Área / Actividad</th>
                        <th>Desde</th>
                        <th class="td-actions">Acciones</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% (asignaciones || []).forEach(a => { %>
                        <tr>
                          <td>
                            <%= a.empleado?.nombre %> <%= a.empleado?.apellidos || '' %>
                            <% if (a.tipo === 'INDIRECTA') { %>
                              <span class="badge" style="margin-left:.3rem; font-size:.72rem; background:rgba(234,88,12,.13); color:#c2410c; border:1px solid rgba(234,88,12,.28);">Indirecta</span>
                            <% } %>
                          </td>
                          <td>
                            <%= a.area?.nombre || '—' %>
                            <% if (a.tipo === 'INDIRECTA' && a.actividadIndirecta) { %>
                              <br><span style="font-size:.78rem; color:var(--ink-dim);"><%= a.actividadIndirecta.nombre %></span>
                            <% } %>
                          </td>
                          <td class="td-mono">
                            <%
                              let desde = '—';
                              if (a.fecha && a.horaInicio) {
                                const d = new Date(a.fecha);
                                const m = String(a.horaInicio).match(/^(\d{1,2}):(\d{2})$/);
                                if (!isNaN(d.getTime()) && m) {
                                  d.setHours(parseInt(m[1], 10), parseInt(m[2], 10), 0, 0);
                                  desde = d.toLocaleString('es-MX', {
                                    timeZone: 'America/Mexico_City',
                                    year: 'numeric', month: '2-digit', day: '2-digit',
                                    hour: '2-digit', minute: '2-digit',
                                  });
                                }
                              } else if (a.createdAt) {
                                const d2 = new Date(a.createdAt);
                                if (!isNaN(d2.getTime())) {
                                  desde = d2.toLocaleString('es-MX', { timeZone: 'America/Mexico_City' });
                                }
                              }
                            %>
                            <%= desde %>
                          </td>
                          <td class="td-actions">
                            <form
                              method="POST"
                              action="/encargado/asignar/<%= a.id %>/finalizar"
                              style="display:inline"
                              class="js-form-finalizar"
                              data-empleado="<%= `${a.empleado?.nombre || ''} ${a.empleado?.apellidos || ''}`.trim() || 'empleado' %>"
                            >
                              <button type="submit" class="btn btn--danger btn--sm">
                                Finalizar
                              </button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>

  <script>
    (function () {
      const areaSel       = document.getElementById('areaId');
      const subSel        = document.getElementById('subtareaSelect');
      const hidSubtareaId = document.getElementById('subtareaId');
      const hidTipo       = document.getElementById('tipoAsignacion');
      const hidActId      = document.getElementById('actividadIndirectaId');
      const fieldModelo   = document.getElementById('fieldModelo');
      const modeloSel     = document.getElementById('modeloId');
      const btnLabel      = document.getElementById('btnAsignarLabel');

      function filterOpciones() {
        if (!subSel) return;
        const area = areaSel ? areaSel.value : '';
        subSel.value = '';
        hidSubtareaId.value = '';
        hidTipo.value = 'DIRECTA';
        hidActId.value = '';

        [...subSel.options].forEach((opt) => {
          if (!opt.value) return;
          if (opt.dataset.tipo === 'DIRECTA') {
            // ocultar directas que no pertenecen al área seleccionada
            opt.hidden = !!area && opt.dataset.area !== area;
          }
          // indirectas siempre visibles — aplican a cualquier área
        });

        updateModelo();
      }

      function updateModelo() {
        const opt = subSel ? subSel.options[subSel.selectedIndex] : null;
        const tipo = opt ? opt.dataset.tipo : 'DIRECTA';

        if (tipo === 'INDIRECTA') {
          hidTipo.value = 'INDIRECTA';
          hidActId.value = opt.dataset.actividadId || '';
          hidSubtareaId.value = '';
          fieldModelo.style.display = 'none';
          modeloSel.required = false;
          modeloSel.value = '';
          if (btnLabel) btnLabel.textContent = 'Registrar actividad';
        } else {
          hidTipo.value = 'DIRECTA';
          hidActId.value = '';
          hidSubtareaId.value = opt ? (opt.dataset.subtareaId || '') : '';
          fieldModelo.style.display = '';
          modeloSel.required = true;
          if (btnLabel) btnLabel.textContent = 'Asignar';
        }
      }

      if (areaSel) areaSel.addEventListener('change', filterOpciones);
      if (subSel)  subSel.addEventListener('change', updateModelo);

      filterOpciones();
    })();
  </script>

  <script>
    (function () {
      const empleadosData = <%- JSON.stringify(empleados || []) %>;
      const btnBuscar   = document.getElementById('btnBuscarNombre');
      const fieldBuscar = document.getElementById('fieldBuscarNombre');
      const inputBuscar = document.getElementById('buscarNombre');
      const dropdown    = document.getElementById('empleadoDropdown');
      const uuidInput   = document.getElementById('uuidQr');

      function normalize(s) { return (s || '').replace(/\s+/g, ' ').trim().toLowerCase(); }

      function labelOf(e) {
        return (e.nombre + ' ' + e.apellidos + (e.areaNombre ? ' — ' + e.areaNombre : '')).replace(/\s+/g, ' ').trim();
      }

      function renderDropdown(list) {
        dropdown.innerHTML = '';
        if (!list.length) { dropdown.style.display = 'none'; return; }
        list.forEach(function (e) {
          const li = document.createElement('li');
          li.textContent = labelOf(e);
          li.style.cssText = 'padding:10px 16px; cursor:pointer; font-size:13px; border-bottom:1px solid rgba(0,0,0,.05);';
          li.addEventListener('mousedown', function (ev) {
            ev.preventDefault();
            uuidInput.value = e.uuid;
            inputBuscar.value = labelOf(e);
            dropdown.style.display = 'none';
          });
          li.addEventListener('mouseenter', function () { li.style.background = 'rgba(29,78,216,.07)'; });
          li.addEventListener('mouseleave', function () { li.style.background = ''; });
          dropdown.appendChild(li);
        });
        dropdown.style.display = '';
      }

      inputBuscar.addEventListener('input', function () {
        const q = normalize(inputBuscar.value);
        const filtered = q
          ? empleadosData.filter(function (e) { return normalize(labelOf(e)).includes(q); })
          : empleadosData;
        renderDropdown(filtered);
      });

      inputBuscar.addEventListener('focus', function () {
        renderDropdown(empleadosData);
      });

      inputBuscar.addEventListener('blur', function () {
        setTimeout(function () { dropdown.style.display = 'none'; }, 150);
      });

      btnBuscar.addEventListener('click', function () {
        const visible = fieldBuscar.style.display !== 'none';
        fieldBuscar.style.display = visible ? 'none' : '';
        dropdown.style.display = 'none';
        if (!visible) { inputBuscar.value = ''; inputBuscar.focus(); }
      });
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>
  <script>
    const btn = document.getElementById('btnScanCam');
    const modal = document.getElementById('qrModal');
    const closeBtn = document.getElementById('btnCloseQr');
    const video = document.getElementById('qrVideo');
    const uuidInput = document.getElementById('uuidQr');
    let stream, rafId;

    async function startScan() {
      modal.style.display = 'grid';
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
        video.srcObject = stream;
        await video.play();
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d', { willReadFrequently: true });

        async function tick() {
          if (video.readyState === video.HAVE_ENOUGH_DATA) {
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            const image = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const code = jsQR(image.data, image.width, image.height);
            if (code && code.data) {
              uuidInput.value = code.data.trim();
              stopScan();
              return;
            }
          }
          rafId = requestAnimationFrame(tick);
        }
        tick();
      } catch (e) {
        alert('No se pudo acceder a la cámara');
        stopScan();
      }
    }

    function stopScan() {
      if (rafId) cancelAnimationFrame(rafId);
      if (stream) stream.getTracks().forEach(t => t.stop());
      video.srcObject = null;
      modal.style.display = 'none';
    }

    btn?.addEventListener('click', startScan);
    closeBtn?.addEventListener('click', stopScan);
    modal?.addEventListener('click', (e) => { if (e.target === modal) stopScan(); });
  </script>

  <script>
    (() => {
      const SwalRef = window.Swal;
      const formAsignar = document.getElementById('formAsignar');

      const KEY_ASSIGN_OK = 'mero_asignacion_ok';
      const KEY_FINISH_OK = 'mero_asignacion_finish_name';

      function cleanText(value) {
        return String(value ?? '').trim();
      }

      function showPendingAlerts() {
        if (!SwalRef) return;

        const assignOk = sessionStorage.getItem(KEY_ASSIGN_OK);
        const finishName = sessionStorage.getItem(KEY_FINISH_OK);

        if (assignOk === '1') {
          sessionStorage.removeItem(KEY_ASSIGN_OK);

          SwalRef.fire({
            icon: 'success',
            title: 'Asignado correctamente',
            confirmButtonText: 'Aceptar'
          });

          return;
        }

        if (finishName) {
          sessionStorage.removeItem(KEY_FINISH_OK);

          SwalRef.fire({
            icon: 'success',
            title: `Asignación de: ${finishName} eliminada`,
            confirmButtonText: 'Aceptar'
          });
        }
      }

      document.addEventListener('DOMContentLoaded', showPendingAlerts);

      if (formAsignar) {
        formAsignar.addEventListener('submit', () => {
          if (!formAsignar.checkValidity()) return;
          sessionStorage.setItem(KEY_ASSIGN_OK, '1');
        });
      }

      document.querySelectorAll('.js-form-finalizar').forEach((form) => {
        form.addEventListener('submit', async (e) => {
          if (!SwalRef) return;

          e.preventDefault();

          const empleado = cleanText(form.dataset.empleado) || 'empleado';

          const result = await SwalRef.fire({
            icon: 'warning',
            title: '¿Desea finalizar la asignación?',
            text: `Se eliminará la asignación de: ${empleado}`,
            showCancelButton: true,
            confirmButtonText: 'Sí, finalizar',
            cancelButtonText: 'Cancelar',
            reverseButtons: true
          });

          if (!result.isConfirmed) return;

          sessionStorage.setItem(KEY_FINISH_OK, empleado);
          form.submit();
        });
      });
    })();
  </script>
</body>
</html>