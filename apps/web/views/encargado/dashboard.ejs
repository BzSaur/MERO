<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <div class="page page--encargado">
          <div class="container">

            <div class="page-header page-header--encargado">
              <div>
                <h1>Panel Encargado</h1>
                <p class="page-header__sub">
                  <svg class="icon"><use href="#icon-clock"/></svg>
                  <%= hoy %>
                </p>
              </div>

              <a href="/encargado/captura" class="btn btn--primary">
                <svg class="icon"><use href="#icon-capture"/></svg>
                Registrar captura
              </a>
            </div>

            <%- include('../partials/flash') %>

            <%# ── Stat summary ── %>
            <%
              const totalAsignados = asignaciones.length;
              let sumEff = 0, countEff = 0;
              metricas.forEach(m => {
                if (m.eficiencia != null) { sumEff += Number(m.eficiencia); countEff++; }
              });
              const avgEff = countEff ? (sumEff / countEff) : null;
            %>

            <div class="grid-stats page--encargado">
              <div class="stat-card stat-card--empleados">
                <div class="stat-card__label">Empleados activos</div>
                <div class="stat-card__value"><%= totalAsignados %></div>
                <div class="stat-card__sub">asignados ahora</div>
                <div class="stat-card__pulse"></div>
              </div>

              <div class="stat-card stat-card--eficiencia">
                <div class="stat-card__label">Eficiencia promedio</div>
                <div class="stat-card__value"><%= fmtEff(avgEff) %></div>
                <div class="stat-card__sub">hoy</div>
                <div class="stat-card__pulse"></div>
              </div>

              <div class="stat-card stat-card--registros">
                <div class="stat-card__label">Registros de hoy</div>
                <div class="stat-card__value"><%= metricas.length %></div>
                <div class="stat-card__sub">slots capturados</div>
                <div class="stat-card__pulse"></div>
              </div>
            </div>

            <% if (metricas.length > 0) { %>
              <%
                const byArea = {};
                metricas.forEach(m => {
                  if (!byArea[m.areaNombre]) byArea[m.areaNombre] = [];
                  byArea[m.areaNombre].push(m);
                });
              %>

              <div class="card" style="margin-bottom: var(--gap-lg)">
                <div class="card__header">
                  <span class="card__title">Eficiencia por slot — hoy</span>
                </div>

                <% Object.entries(byArea).forEach(([area, slots]) => { %>
                  <div class="slot-area">
                    <div class="slot-area__header">
                      <span class="slot-area__name"><%= area %></span>
                      <% const last = slots[slots.length - 1]; %>
                      <span class="eff-value <%= effClass(last?.eficiencia) %>">
                        <%= fmtEff(last?.eficiencia) %>
                      </span>
                    </div>

                    <div class="slot-strip slot-strip--lg">
                      <% slots.forEach(s => { %>
                        <div class="slot-strip__seg slot-strip__seg--<%= slotClass(s.eficiencia) %>"
                             title="<%= s.slotHora %>h — <%= fmtEff(s.eficiencia) %>">
                        </div>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <div class="card card--asignaciones">
              <div class="card__header">
                <div class="card__header-left">
                  <span class="card__title">Asignaciones activas</span>
                  <span class="badge badge--none"><%= asignaciones.length %> activas</span>
                </div>

                <a href="/encargado/asignar" class="btn btn--ghost btn--sm">
                  <svg class="icon"><use href="#icon-assign"/></svg>
                  Gestionar
                </a>
              </div>

              <% if (!asignaciones.length) { %>
                <div class="empty empty--asignaciones">
                  <p class="empty__text">Sin asignaciones activas.</p>
                  <p class="empty__sub">Cuando asignes personal, aparecerán aquí en tiempo real.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignaciones">
                  <table class="table table--asignaciones">
                    <thead>
                      <tr>
                        <th>Empleado</th>
                        <th>Área</th>
                        <th class="td-hide-mobile">Subtarea</th>
                        <th class="td-hide-mobile">Modelo</th>
                        <th>Desde</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% asignaciones.forEach(a => { %>
                        <tr>
                          <td>
                            <%= a.empleado?.nombre %> <%= a.empleado?.apellidos || '' %>
                          </td>

                          <td>
                            <span class="badge badge--none"><%= a.area?.nombre %></span>
                          </td>

                          <td class="td-hide-mobile"><%= a.subtarea?.nombre %></td>
                          <td class="td-hide-mobile"><%= a.modelo?.nombre %></td>
                          <td class="td-mono"><%= fmtDate(a.createdAt) %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>

  <script src="/js/main.js"></script>
</body>
</html>