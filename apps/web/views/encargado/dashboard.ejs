<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <div class="page page--encargado page--metrics page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Panel Encargado</h1>
                <h2>
                  <p class="page-header__sub" style="display:flex; align-items:center; gap:.5rem;">
                    <span><%= hoy %></span>
                  </p>
                </h2>
              </div>

              <a href="/encargado/captura" class="btn btn--history">
                <svg class="icon"><use href="#icon-capture"/></svg>
                Registrar captura
              </a>
            </div>

            <%- include('../partials/flash') %>

            <%
              const totalAsignados = asignaciones.length;
              let sumEff = 0, countEff = 0;

              metricas.forEach(function(m) {
                if (m.eficiencia != null) {
                  sumEff += Number(m.eficiencia);
                  countEff++;
                }
              });

              const avgEff = countEff ? (sumEff / countEff) : null;
            %>

            <div class="grid-stats grid-stats--metrics" style="margin-bottom:var(--gap-lg)">
              <div class="stat-card stat-card--gradient stat-card--green">
                <div class="stat-card__label">Eficiencia promedio</div>
                <div class="stat-card__value"><%= fmtEff(avgEff) %></div>
                <div class="stat-card__sub">promedio todos los slots</div>
              </div>

              <div class="stat-card stat-card--gradient stat-card--indigo">
                <div class="stat-card__label">Registros de hoy</div>
                <div class="stat-card__value"><%= metricas.length %></div>
                <div class="stat-card__sub">slots capturados</div>
              </div>

              <div class="stat-card stat-card--gradient stat-card--blue">
                <div class="stat-card__label">Empleados activos</div>
                <div class="stat-card__value"><%= totalAsignados %></div>
                <div class="stat-card__sub">asignados ahora</div>
              </div>
            </div>

            <% if (metricas.length > 0) { %>
              <%
                const byArea = {};

                metricas.forEach(function(m) {
                  let areaKey = 'Sin área';

                  if (m && m.areaNombre) {
                    areaKey = String(m.areaNombre);
                  } else if (m && m.area && m.area.nombre) {
                    areaKey = String(m.area.nombre);
                  }

                  if (!byArea[areaKey]) {
                    byArea[areaKey] = [];
                  }

                  byArea[areaKey].push(m);
                });
              %>

              <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
                <div class="card__header">
                  <h3><span class="card__title">Eficiencia por slot — hoy</span></h3>
                  <span class="slot-legend">Verde &gt;=90% / Ámbar 70-89% / Rojo &lt;70%</span>
                </div>

                <div style="padding: var(--gap) var(--gap-lg);">
                  <% Object.entries(byArea).forEach(function(entry) { 
                    const area = entry[0];
                    const slots = entry[1];
                    const last = slots && slots.length ? slots[slots.length - 1] : null;
                  %>
                    <div class="slot-area">
                      <div class="slot-area__header">
                        <span class="slot-area__name"><%= area %></span>
                        <span class="eff-value <%= effClass(last ? last.eficiencia : null) %>">
                          <%= fmtEff(last ? last.eficiencia : null) %>
                        </span>
                      </div>

                      <div class="slot-strip slot-strip--lg">
                        <% slots.forEach(function(s) { %>
                          <div
                            class="slot-strip__seg slot-strip__seg--<%= slotClass(s ? s.eficiencia : null) %>"
                            title="<%= (s && s.slotHora != null ? s.slotHora + ':00' : 'Sin hora') %> — <%= fmtEff(s ? s.eficiencia : null) %>">
                          </div>
                        <% }) %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>

            <div class="card card--asignar card--asignar-act">
              <div class="card__header card__header--usuarios card__header--split">
                <div class="card__header-left">
                  <h3><span class="card__title">Asignaciones activas</span></h3>
                  <span class="badge badge--ok"><%= asignaciones.length %></span>
                </div>

                <a href="/encargado/asignar" class="btn btn--manage">
                  <svg class="icon"><use href="#icon-assign"/></svg>
                  Gestionar
                </a>
              </div>

              <% if (!asignaciones.length) { %>
                <div class="empty empty--asignar">
                  <p class="empty__text">Sin asignaciones activas.</p>
                  <p class="empty__sub">Cuando asignes personal, aparecerán aquí en tiempo real.</p>
                </div>
              <% } else { %>
                <div class="table-wrap table-wrap--asignar table-wrap--blue">
                  <table class="table table--asignar table--blue">
                    <thead>
                      <tr>
                        <th>Empleado</th>
                        <th>Área</th>
                        <th class="td-hide-mobile">Subtarea</th>
                        <th class="td-hide-mobile">Modelo</th>
                        <th>Desde</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% asignaciones.forEach(function(a) { %>
                        <tr>
                          <td><%= a.empleado?.nombre %> <%= a.empleado?.apellidos || '' %></td>
                          <td><span class="badge badge--none"><%= a.area?.nombre %></span></td>
                          <td class="td-hide-mobile"><%= a.subtarea?.nombre %></td>
                          <td class="td-hide-mobile"><%= a.modelo?.nombre %></td>
                          <td class="td-mono"><%= fmtDate(a.createdAt) %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
</body>
</html>