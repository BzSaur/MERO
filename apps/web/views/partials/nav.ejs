<nav class="nav">
  <a href="/" class="nav__brand">
    <svg class="icon" style="font-size:18px"><use href="#icon-logo"/></svg>
    MERO
  </a>

  <% if (user) { %>
    <button
      type="button"
      class="nav__toggle"
      aria-label="Menu"
      aria-expanded="false"
      onclick="
        (function(btn){
          const nav = btn.closest('.nav');
          const links = nav.querySelector('.nav__links');
          links.classList.toggle('open');
          btn.classList.toggle('open');
          btn.setAttribute('aria-expanded', links.classList.contains('open') ? 'true' : 'false');
        })(this)
      ">
      <svg class="icon"><use href="#icon-menu"/></svg>
    </button>

    <ul class="nav__links">
      <% if (user.rol === 'ADMIN' || user.rol === 'ENCARGADO') { %>
        <li>
          <a href="/encargado"
             class="<%= currentUrl.startsWith('/encargado') && currentUrl !== '/encargado/asignar' ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-capture"/></svg>
            Captura
          </a>
        </li>
        <li>
          <a href="/encargado/asignar"
             class="<%= currentUrl === '/encargado/asignar' ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-assign"/></svg>
            Asignar
          </a>
        </li>
      <% } %>

      <% if (user.rol === 'ADMIN') { %>
        <li>
          <a href="/admin" class="<%= currentUrl === '/admin' ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-dashboard"/></svg>
            Admin
          </a>
        </li>
        <li>
          <a href="/admin/usuarios" class="<%= currentUrl.startsWith('/admin/usuarios') ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-users"/></svg>
            Usuarios
          </a>
        </li>
        <li>
          <a href="/admin/empleados" class="<%= currentUrl.startsWith('/admin/empleados') ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-person"/></svg>
            Empleados
          </a>
        </li>
        <li>
          <a href="/admin/catalogos/areas" class="<%= currentUrl.startsWith('/admin/catalogos') ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-catalog"/></svg>
            Catalogos
          </a>
        </li>
        <li>
          <a href="/admin/auditoria" class="<%= currentUrl.startsWith('/admin/auditoria') ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-audit"/></svg>
            Auditoria
          </a>
        </li>
      <% } %>

      <% if (user.rol === 'CONSULTOR' || user.rol === 'ADMIN') { %>
        <li>
          <a href="/consultor" class="<%= currentUrl === '/consultor' ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-chart"/></svg>
            Metricas
          </a>
        </li>
        <li>
          <a href="/consultor/historico" class="<%= currentUrl.startsWith('/consultor/historico') ? 'active' : '' %>">
            <svg class="icon"><use href="#icon-history"/></svg>
            Historico
          </a>
        </li>
      <% } %>
    </ul>

    <div class="nav__end">
      <span class="nav__user"><%= user.nombre %></span>
     <a href="/logout" class="nav__logout" id="logoutBtn">
      <svg class="icon"><use href="#icon-logout"/></svg>
      Salir
    </a>
    </div>
  <% } %>
</nav>

<script defer src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script defer src="/js/nav.js?v=1"></script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if(!nav) return;

  const linksWrap = nav.querySelector('.nav__links');
  if(!linksWrap) return;

  const links = Array.from(linksWrap.querySelectorAll('a'));
  if(!links.length) return;

  function setPillTo(el, show=true){
    const wrapRect = linksWrap.getBoundingClientRect();
    const r = el.getBoundingClientRect();
    const x = (r.left - wrapRect.left);
    const w = r.width;

    linksWrap.style.setProperty('--pill-x', x + 'px');
    linksWrap.style.setProperty('--pill-w', w + 'px');
    linksWrap.style.setProperty('--pill-visible', show ? '1' : '0');
  }

  function getActive(){
    return linksWrap.querySelector('a.active') || links[0];
  }

  // Inicial: ir al activo
  const active = getActive();
  setPillTo(active, true);

  // Recalcular en resize (por fuentes/zoom)
  window.addEventListener('resize', () => setPillTo(getActive(), true), { passive:true });

  // Hover/focus: mover indicador
  links.forEach(a => {
    a.addEventListener('mouseenter', () => setPillTo(a, true));
    a.addEventListener('focus', () => setPillTo(a, true));
    a.addEventListener('click', () => setPillTo(a, true)); // antes de navegar
  });

  // Al salir: volver al activo
  linksWrap.addEventListener('mouseleave', () => setPillTo(getActive(), true));
})();
</script>