<%
  const displayName =
    user?.nombre ||
    user?.Nombre_Completo ||
    user?.name ||
    user?.email ||
    'Usuario';

  const displayEmail =
    user?.email ||
    user?.Email_Office365 ||
    user?.correo ||
    '';

  const initial = String(displayName).trim().charAt(0).toUpperCase() || 'U';
%>

<nav class="navbar">
  <button
    class="btn-icon"
    id="sidebarToggle"
    type="button"
    aria-label="Abrir/cerrar menú"
    title="Menú"
  >
    <i class="bi bi-list"></i>
  </button>

  <h1 class="page-title"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>

  <% if (user) { %>
    <div class="ms-auto">
      <div class="user-dropdown" id="userDropdown">
        <button
          class="user-dropdown-toggle"
          id="userDropdownToggle"
          type="button"
          aria-expanded="false"
          aria-controls="userMenu"
        >
          <div class="user-avatar"><span><%= initial %></span></div>
          <span class="user-name d-none d-md-inline"><%= displayName %></span>
          <i class="bi bi-chevron-down" style="color: #94a3b8; font-size: 0.8rem;"></i>
        </button>

        <div class="dropdown-menu" id="userMenu">
          <div class="dropdown-header">
            <strong><%= displayName %></strong>
            <% if (displayEmail) { %>
              <small><%= displayEmail %></small>
            <% } %>
          </div>

          <div class="dropdown-divider"></div>

          <a href="/logout" class="dropdown-item text-danger" id="logoutBtn">
            <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
          </a>
        </div>
      </div>
    </div>
  <% } %>
</nav>