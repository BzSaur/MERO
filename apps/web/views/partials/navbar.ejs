<!-- Navbar -->
<nav class="navbar">
  <button class="btn-icon" id="sidebarToggle" type="button" aria-label="Abrir/cerrar menú" title="Menú">
    <i class="bi bi-list"></i>
  </button>

  <h1 class="page-title"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>

  <div class="d-flex align-items-center gap-2 ms-auto">
    <div class="dropdown">
      <button class="btn-icon" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notificaciones">
        <i class="bi bi-bell"></i>
        <span class="badge-dot"></span>
      </button>

      <div class="dropdown-menu dropdown-menu-end notification-dropdown">
        <h6 class="dropdown-header">Notificaciones</h6>
        <div class="dropdown-divider"></div>

        <a href="#" class="dropdown-item">
          <div class="notification-item">
            <i class="bi bi-info-circle text-info"></i>
            <div>
              <p class="mb-0">Sistema actualizado</p>
              <small class="text-body-secondary">Hace 5 minutos</small>
            </div>
          </div>
        </a>

        <div class="dropdown-divider"></div>
        <a href="#" class="dropdown-item text-center">Ver todas</a>
      </div>
    </div>

    <% if (user) { %>
      <div class="dropdown">
        <button class="user-dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <div class="user-avatar-sm">
            <i class="bi bi-person"></i>
          </div>
          <span class="d-none d-md-inline"><%= user.Nombre_Completo %></span>
          <i class="bi bi-chevron-down"></i>
        </button>

        <div class="dropdown-menu dropdown-menu-end">
          <div class="dropdown-header">
            <strong><%= user.Nombre_Completo %></strong><br>
            <small class="text-body-secondary"><%= user.Email_Office365 %></small>
          </div>

          <div class="dropdown-divider"></div>

          <a href="/perfil" class="dropdown-item">
            <i class="bi bi-person me-2"></i> Mi Perfil
          </a>

          <div class="dropdown-divider"></div>

          <a href="/auth/logout" class="dropdown-item text-danger">
            <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
          </a>
        </div>
      </div>
    <% } %>
  </div>
</nav>