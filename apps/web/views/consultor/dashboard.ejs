<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <!-- ✅ Hereda look de Histórico (cards/table/header) -->
        <div class="page page--encargado page--metrics page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Métricas — Hoy</h1>
                <h2>
                  <p class="page-header__sub" style="display:flex; align-items:center; gap:.5rem;">
                    <span><%= hoy %></span>
                  </p>
                </h2>
              </div>

              <a href="/consultor/historico" class="btn btn--back btn--history">
                <svg class="icon"><use href="#icon-history"/></svg>
                Ver histórico
              </a>
            </div>

            <%- include('../partials/flash') %>

            <%
              let sumEff = 0, countEff = 0;
              metricas.forEach(m => {
                if (m.eficiencia != null) { sumEff += Number(m.eficiencia); countEff++; }
              });
              const avgEff = countEff ? (sumEff / countEff) : null;
            %>

            <!-- ✅ Cards -->
            <div class="grid-stats grid-stats--metrics" style="margin-bottom:var(--gap-lg)">
              <div class="stat-card stat-card--gradient stat-card--green">
                <div class="stat-card__label">Eficiencia global</div>
                <div class="stat-card__value"><%= fmtEff(avgEff) %></div>
                <div class="stat-card__sub">promedio todos los slots</div>
              </div>

              <div class="stat-card stat-card--gradient stat-card--indigo">
                <div class="stat-card__label">Slots registrados</div>
                <div class="stat-card__value"><%= metricas.length %></div>
                <div class="stat-card__sub">hoy</div>
              </div>

              <div class="stat-card stat-card--gradient stat-card--blue">
                <div class="stat-card__label">Empleados activos</div>
                <div class="stat-card__value"><%= asignaciones.length %></div>
                <div class="stat-card__sub">asignados ahora</div>
              </div>
            </div>

            <% if (metricas.length > 0) { %>
              <%
                const byArea = {};
                metricas.forEach(m => {
                  if (!byArea[m.areaNombre]) byArea[m.areaNombre] = [];
                  byArea[m.areaNombre].push(m);
                });
              %>

              <!-- ✅ Panel -->
              <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
                <div class="card__header">
                  <h3><span class="card__title">Slot strip por área</span></h3>
                  <span class="badge badge--none">Verde &gt;=90% / Ámbar 70-89% / Rojo &lt;70%</span>
                </div>

                <div style="padding: var(--gap) var(--gap-lg);">
                  <% Object.entries(byArea).forEach(([area, slots]) => {
                       let areaSum = 0, areaCount = 0;
                       slots.forEach(s => { if (s.eficiencia != null) { areaSum += Number(s.eficiencia); areaCount++; } });
                       const areaAvg = areaCount ? (areaSum / areaCount) : null;
                  %>
                    <div class="slot-area">
                      <div class="slot-area__header">
                        <span class="slot-area__name"><%= area %></span>
                        <span class="eff-value <%= effClass(areaAvg) %>"><%= fmtEff(areaAvg) %></span>
                      </div>

                      <div class="slot-strip slot-strip--lg">
                        <% slots.forEach(s => { %>
                          <div
                            class="slot-strip__seg slot-strip__seg--<%= slotClass(s.eficiencia) %>"
                            title="<%= s.slotHora %>h -- real: <%= s.cantidadReal %> / est: <%= s.cantidadEstandar %> -- <%= fmtEff(s.eficiencia) %>"
                          ></div>
                        <% }) %>
                      </div>

                      <div class="slot-area__hours">
                        <% slots.forEach(s => { %>
                          <span class="slot-area__hour"><%= s.slotHora %>h</span>
                        <% }) %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>

              <!-- ✅ RESULTADOS -->
              <div class="card card--asignar card--asignar-act">
                <!-- ✅ MISMA CLASE QUE USUARIOS -->
                <div class="card__header card__header--usuarios">
                  <h3><span class="card__title">Resultados</span></h3>
                  <span class="badge badge--ok"><%= metricas.length %></span>
                </div>

                <div class="table-wrap table-wrap--asignar table-wrap--blue">
                  <table class="table table--asignar table--blue">
                    <thead>
                      <tr>
                        <th>Área</th>
                        <th>Slot</th>
                        <th class="td-hide-mobile">Real</th>
                        <th class="td-hide-mobile">Estándar</th>
                        <th>Eficiencia</th>
                      </tr>
                    </thead>

                    <tbody>
                      <% metricas.forEach(m => { %>
                        <tr>
                          <td><%= m.areaNombre %></td>
                          <td class="td-mono"><%= m.slotHora %>:00</td>
                          <td class="td-mono td-hide-mobile"><%= m.cantidadReal %></td>
                          <td class="td-mono td-hide-mobile"><%= m.cantidadEstandar %></td>
                          <td>
                            <span class="eff-value <%= effClass(m.eficiencia) %>">
                              <%= fmtEff(m.eficiencia) %>
                            </span>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>

            <% } else { %>

              <!-- ✅ Empty -->
              <div class="card card--asignar card--asignar-act">
                <!-- ✅ MISMA CLASE QUE USUARIOS -->
                <div class="card__header card__header--usuarios">
                  <h3><span class="card__title">Resultados</span></h3>
                  <span class="badge badge--ok">0</span>
                </div>

                <div class="empty empty--asignar">
                  <p class="empty__text">Sin capturas registradas hoy.</p>
                  <p class="empty__sub">Cuando existan capturas, aparecerán aquí en tiempo real.</p>
                </div>
              </div>

            <% } %>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
</body>
</html>