<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>

<body class="sidebar-collapsed">
  <%- include('../partials/icons') %>

  <div class="wrapper">
    <%- include('../partials/sidebar') %>

    <div class="main-content">
      <%- include('../partials/navbar') %>

      <main class="content">
        <div class="page page--encargado page--metrics page--asignar page--areas">
          <div class="container">

            <div class="page-header">
              <div>
                <h1>Métricas — Hoy</h1>
                <h2>
                  <p class="page-header__sub" style="display:flex; align-items:center; gap:.5rem;">
                    <span><%= hoy %></span>
                  </p>
                </h2>
              </div>

              <a href="/consultor/historico" class="btn btn--back btn--history">
                <svg class="icon"><use href="#icon-history"/></svg>
                Ver histórico
              </a>
            </div>

            <%- include('../partials/flash') %>

            <%
              // =========================
              // Normalizadores (API vs UI)
              // =========================

              function getAreaName(m) {
                return (
                  m?.areaNombre ||
                  m?.area?.nombre ||
                  m?.area_name ||
                  m?.areaName ||
                  (typeof m?.area === 'string' ? m.area : null) ||
                  (m?.areaId != null ? `Área #${m.areaId}` : 'Área')
                );
              }

              function getSlotHora(m) {
                return (
                  m?.slotHora ??
                  m?.slot ??
                  m?.hora ??
                  null
                );
              }

              function getReal(m) {
                const v =
                  m?.cantidadReal ??
                  m?.real ??
                  m?.cantidad ??
                  m?.producido ??
                  null;

                return (v == null ? null : Number(v));
              }

              function getStd(m) {
                const v =
                  m?.cantidadEstandar ??
                  m?.estandar ??
                  m?.standard ??
                  m?.meta ??
                  null;

                if (v == null) return null;

                const n = Number(v);

                if (!Number.isFinite(n) || n <= 0) return null;

                return n;
              }

              function getEff(m) {
                const v =
                  m?.eficiencia ??
                  m?.eficienciaPct ??
                  m?.efficiencia ??
                  m?.eff ??
                  null;

                if (v == null) return null;

                const n = Number(v);
                if (!Number.isFinite(n)) return null;

                return n;
              }

              function slotClass(val) {
                if (val == null || !Number.isFinite(Number(val))) return 'none';
                if (Number(val) >= 90) return 'ok';
                if (Number(val) >= 70) return 'warn';
                return 'fail';
              }

              function effClass(val) {
                return slotClass(val);
              }

              function fmtEff(val) {
                if (val == null || !Number.isFinite(Number(val))) return '—';
                return Number(val).toFixed(1) + '%';
              }

              let sumEff = 0, countEff = 0;
              metricas.forEach(m => {
                const e = getEff(m);
                if (e != null) {
                  sumEff += e;
                  countEff++;
                }
              });
              const avgEff = countEff ? (sumEff / countEff) : null;

              const okCount = metricas.filter(m => {
                const e = getEff(m);
                return e != null && e >= 90;
              }).length;

              const warnCount = metricas.filter(m => {
                const e = getEff(m);
                return e != null && e >= 70 && e < 90;
              }).length;

              const failCount = metricas.filter(m => {
                const e = getEff(m);
                return e != null && e < 70;
              }).length;
            %>

            <!-- Cards -->
            <div class="grid-stats grid-stats--metrics" style="margin-bottom:var(--gap-lg)">
              <div class="stat-card stat-card--gradient stat-card--green">
                <div class="stat-card__label">Eficiencia global</div>
                <div class="stat-card__value"><%= fmtEff(avgEff) %></div>
                <div class="stat-card__sub">promedio todos los slots</div>
              </div>

              <div class="stat-card stat-card--gradient stat-card--indigo">
                <div class="stat-card__label">Slots registrados</div>
                <div class="stat-card__value"><%= metricas.length %></div>
                <div class="stat-card__sub">hoy</div>
              </div>

              <div class="stat-card stat-card--gradient stat-card--blue">
                <div class="stat-card__label">Empleados activos</div>
                <div class="stat-card__value"><%= asignaciones.length %></div>
                <div class="stat-card__sub">asignados ahora</div>
              </div>
            </div>
            
            <% if (metricas.length > 0) { %>
              <%
                const byArea = {};

                metricas.forEach(m => {
                  const key = getAreaName(m);
                  if (!byArea[key]) byArea[key] = [];
                  byArea[key].push(m);
                });

                Object.values(byArea).forEach(arr => {
                  arr.sort((a, b) => Number(getSlotHora(a) ?? 0) - Number(getSlotHora(b) ?? 0));
                });
              %>

              <!-- Panel strip por área -->
              <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
                <div class="card__header card__header--metrics-strip">
                  <div>
                    <h3><span class="card__title">Slot strip por área</span></h3>
                  </div>

                  <div class="metrics-legend">
                    <span class="badge-summary">
                      <i class="bi bi-circle-fill text-success" style="font-size: 0.6rem;"></i>
                      Verde (≥90%)
                    </span>
                    <span class="badge-summary">
                      <i class="bi bi-circle-fill text-warning" style="font-size: 0.6rem;"></i>
                      Riesgo (70-89%)
                    </span>
                    <span class="badge-summary">
                      <i class="bi bi-circle-fill text-danger" style="font-size: 0.6rem;"></i>
                      Crítico (&lt;70%)
                    </span>
                  </div>
                </div>

                <div class="metrics-strip-body">
                  <% Object.entries(byArea).forEach(([area, slots]) => {
                       let areaSum = 0, areaCount = 0;

                       slots.forEach(s => {
                         const e = getEff(s);
                         if (e != null) {
                           areaSum += e;
                           areaCount++;
                         }
                       });

                       const areaAvg = areaCount ? (areaSum / areaCount) : null;
                  %>
                    <div class="slot-area">
                      <div class="slot-area__header">
                        <span class="slot-area__name"><%= area %></span>
                        <span class="eff-value <%= effClass(areaAvg) %>"><%= fmtEff(areaAvg) %></span>
                      </div>

                      <div class="slot-strip slot-strip--lg">
                        <% slots.forEach(s => {
                             const sh = getSlotHora(s);
                             const r  = getReal(s);
                             const st = getStd(s);
                             const e  = getEff(s);
                        %>
                          <div
                            class="slot-strip__seg slot-strip__seg--<%= slotClass(e) %>"
                            title="<%= sh %>h — real: <%= (r == null ? '—' : r) %> / est: <%= (st == null ? '—' : st) %> — <%= fmtEff(e) %>"></div>
                        <% }) %>
                      </div>

                      <div class="slot-area__hours">
                        <% slots.forEach(s => { %>
                          <span class="slot-area__hour"><%= getSlotHora(s) %>h</span>
                        <% }) %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>

              <!-- Gráficas por área (eficiencia por slot) -->
              <%
                const hoyChartData = {};
                metricas.forEach(m => {
                  const area = getAreaName(m);
                  const sh   = getSlotHora(m);
                  const eff  = getEff(m);
                  if (!hoyChartData[area]) hoyChartData[area] = {};
                  if (!hoyChartData[area][sh]) hoyChartData[area][sh] = [];
                  if (eff != null) hoyChartData[area][sh].push(eff);
                });
              %>
              <% Object.entries(hoyChartData).forEach(([area, slotsMap], ci) => {
                   const slotKeys = Object.keys(slotsMap).map(Number).sort((a,b) => a-b);
                   const slotLabels = slotKeys.map(h => h + ':00');
                   const slotValues = slotKeys.map(h => {
                     const vals = slotsMap[h];
                     return vals.length ? Math.round(vals.reduce((a,b) => a+b, 0) / vals.length * 10) / 10 : 0;
                   });
              %>
              <div class="card card--asignar" style="margin-bottom:var(--gap-lg)">
                <div class="card__header card__header--usuarios">
                  <h3><span class="card__title">Eficiencia por slot — <%= area %></span></h3>
                  <span class="badge badge--none" style="font-size:.78rem;">hoy</span>
                </div>
                <div style="padding:var(--gap) var(--gap-lg) var(--gap-lg);">
                  <canvas id="hoy-chart-<%= ci %>" height="90"
                    data-labels="<%= JSON.stringify(slotLabels) %>"
                    data-values="<%= JSON.stringify(slotValues) %>">
                  </canvas>
                </div>
              </div>
              <% }) %>

              <!-- Árbol expandible: Área → Subtarea → Empleado → Slots -->
              <%
                // Build tree
                const hoyTree = {};
                metricas.forEach(m => {
                  const area = getAreaName(m);
                  const sub  = m?.subtarea || m?.subtareaNombre || 'Sin subtarea';
                  const emp  = m?.empleado || m?.empleadoNombre || '—';
                  if (!hoyTree[area]) hoyTree[area] = {};
                  if (!hoyTree[area][sub]) hoyTree[area][sub] = {};
                  if (!hoyTree[area][sub][emp]) hoyTree[area][sub][emp] = [];
                  hoyTree[area][sub][emp].push(m);
                });

                function avgHoy(arr) {
                  const valid = arr.filter(x => x != null && Number.isFinite(Number(x)));
                  return valid.length ? valid.reduce((s,x) => s + Number(x), 0) / valid.length : null;
                }
              %>
              <div class="card card--asignar card--asignar-act card--usuarios">
                <div class="card__header card__header--usuarios">
                  <h3><span class="card__title">Detalle por área</span></h3>
                  <span class="badge badge--ok"><%= metricas.length %></span>
                </div>
                <div class="table-wrap table-wrap--asignar table-wrap--clean">
                  <table class="table table--asignar table--clean rexp-table">
                    <thead>
                      <tr>
                        <th style="width:2rem"></th>
                        <th>Área / Subtarea / Empleado</th>
                        <th style="width:7rem;text-align:right">Eficiencia</th>
                        <th style="width:8rem" class="td-hide-mobile">Slots hoy</th>
                      </tr>
                    </thead>
                    <tbody>
                    <% let hAIdx = 0; Object.entries(hoyTree).forEach(([area, subs]) => {
                         const allCaps = Object.values(subs).flatMap(em => Object.values(em).flat());
                         const aAvg = avgHoy(allCaps.map(m => getEff(m)));
                         const allSlots = allCaps.sort((a,b) => (getSlotHora(a)??0)-(getSlotHora(b)??0));
                         const hAId = 'hoy-area-' + hAIdx++;
                    %>
                      <tr class="rexp-row rexp-row--area" data-target="<%= hAId %>" onclick="toggleRexp(this)">
                        <td class="rexp-toggle"><span class="rexp-arrow">▶</span></td>
                        <td><strong><%= area %></strong></td>
                        <td style="text-align:right">
                          <span class="eff-badge eff-badge--<%= effClass(aAvg) %>"><%= fmtEff(aAvg) %></span>
                        </td>
                        <td class="td-hide-mobile">
                          <div class="slot-strip slot-strip--sm">
                            <% allSlots.forEach(s => { %>
                              <div class="slot-strip__seg slot-strip__seg--<%= effClass(getEff(s)) %>"
                                title="<%= getSlotHora(s) %>:00 — <%= fmtEff(getEff(s)) %>"></div>
                            <% }) %>
                          </div>
                        </td>
                      </tr>

                      <% let hSIdx = 0; Object.entries(subs).forEach(([sub, empMap]) => {
                           const subCaps = Object.values(empMap).flat();
                           const sAvg = avgHoy(subCaps.map(m => getEff(m)));
                           const hSId = hAId + '-sub-' + hSIdx++;
                      %>
                        <tr class="rexp-row rexp-row--sub rexp-child--<%= hAId %>" style="display:none"
                            data-target="<%= hSId %>" onclick="toggleRexp(this)">
                          <td class="rexp-toggle" style="padding-left:1.8rem">
                            <span class="rexp-arrow rexp-arrow--sm">▶</span>
                          </td>
                          <td style="padding-left:1.4rem;color:rgba(15,23,42,.72);font-size:.9rem"><%= sub %></td>
                          <td style="text-align:right">
                            <span class="eff-badge eff-badge--<%= effClass(sAvg) %>" style="font-size:.78rem"><%= fmtEff(sAvg) %></span>
                          </td>
                          <td class="td-hide-mobile">
                            <div class="slot-strip slot-strip--sm">
                              <% subCaps.sort((a,b) => (getSlotHora(a)??0)-(getSlotHora(b)??0)).forEach(s => { %>
                                <div class="slot-strip__seg slot-strip__seg--<%= effClass(getEff(s)) %>"
                                  title="<%= getSlotHora(s) %>:00 — <%= fmtEff(getEff(s)) %>"></div>
                              <% }) %>
                            </div>
                          </td>
                        </tr>

                        <% let hEIdx = 0; Object.entries(empMap).forEach(([emp, rows]) => {
                             const eAvg = avgHoy(rows.map(m => getEff(m)));
                             const hEId = hSId + '-emp-' + hEIdx++;
                        %>
                          <tr class="rexp-row rexp-row--sub rexp-child--<%= hSId %>" style="display:none"
                              data-target="<%= hEId %>" onclick="toggleRexp(this)">
                            <td class="rexp-toggle" style="padding-left:3rem">
                              <span class="rexp-arrow rexp-arrow--sm">▶</span>
                            </td>
                            <td style="padding-left:2.6rem;font-size:.88rem;font-weight:700"><%= emp %></td>
                            <td style="text-align:right">
                              <span class="eff-badge eff-badge--<%= effClass(eAvg) %>" style="font-size:.75rem"><%= fmtEff(eAvg) %></span>
                            </td>
                            <td class="td-hide-mobile">
                              <div class="slot-strip slot-strip--sm">
                                <% rows.sort((a,b) => (getSlotHora(a)??0)-(getSlotHora(b)??0)).forEach(s => { %>
                                  <div class="slot-strip__seg slot-strip__seg--<%= effClass(getEff(s)) %>"
                                    title="<%= getSlotHora(s) %>:00 — <%= fmtEff(getEff(s)) %>"></div>
                                <% }) %>
                              </div>
                            </td>
                          </tr>

                          <% rows.sort((a,b) => (getSlotHora(a)??0)-(getSlotHora(b)??0)).forEach(r => { %>
                            <tr class="rexp-row rexp-row--slot rexp-child--<%= hEId %>" style="display:none">
                              <td></td>
                              <td style="padding-left:4rem;font-size:.82rem;color:rgba(15,23,42,.55)">
                                <%= getSlotHora(r) %>:00
                              </td>
                              <td style="text-align:right">
                                <span class="eff-badge eff-badge--<%= effClass(getEff(r)) %>" style="font-size:.72rem">
                                  <%= fmtEff(getEff(r)) %>
                                </span>
                              </td>
                              <td class="td-hide-mobile" style="font-size:.78rem;color:rgba(15,23,42,.45)">
                                <%= getReal(r) ?? '—' %> pzas / std <%= getStd(r) ?? '—' %>
                              </td>
                            </tr>
                          <% }) %>
                        <% }) %>
                      <% }) %>
                    <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>

            <% } else { %>

              <div class="card card--asignar card--asignar-act">
                <div class="card__header card__header--usuarios">
                  <h3><span class="card__title">Resultados</span></h3>
                  <span class="badge badge--ok">0</span>
                </div>

                <div class="empty empty--asignar">
                  <p class="empty__text">Sin capturas registradas hoy.</p>
                  <p class="empty__sub">Cuando existan capturas, aparecerán aquí en tiempo real.</p>
                </div>
              </div>

            <% } %>

          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="sidebarOverlay"></div>
  <script src="/js/main.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script>
    function effColor(val) {
      if (val == null) return 'rgba(148,163,184,.4)';
      if (val >= 90) return 'rgba(34,197,94,.75)';
      if (val >= 70) return 'rgba(234,179,8,.75)';
      return 'rgba(239,68,68,.75)';
    }
    document.querySelectorAll('canvas[data-labels]').forEach(canvas => {
      const labels = JSON.parse(canvas.dataset.labels);
      const values = JSON.parse(canvas.dataset.values);
      new Chart(canvas, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Eficiencia (%)',
            data: values,
            backgroundColor: values.map(effColor),
            borderRadius: 6,
            borderSkipped: false,
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: ctx => ctx.parsed.y != null ? ctx.parsed.y.toFixed(1) + '%' : '—' } }
          },
          scales: {
            y: {
              min: 0, max: 120,
              ticks: { callback: v => v + '%', stepSize: 20, font: { size: 11 } },
              grid: { color: 'rgba(15,23,42,.06)' }
            },
            x: { ticks: { font: { size: 11 } }, grid: { display: false } }
          }
        }
      });
    });

    document.querySelectorAll('[class*="rexp-child--"]').forEach(function(r) {
      r.classList.add('rexp-hidden');
      r.style.display = '';
    });

    function getParentKey(row) {
      var match = row.className.match(/rexp-child--([\w-]+)/);
      return match ? match[1] : null;
    }

    function collapseRexp(target) {
      document.querySelectorAll('.rexp-child--' + target).forEach(function(c) {
        c.classList.add('rexp-hidden');
        c.classList.remove('rexp-row--open');
        var a = c.querySelector('.rexp-arrow');
        if (a) a.textContent = '▶';
        if (c.dataset.target) collapseRexp(c.dataset.target);
      });
    }

    function collapseSiblings(row) {
      var parentKey = getParentKey(row);
      var siblings = parentKey
        ? document.querySelectorAll('.rexp-child--' + parentKey + '.rexp-row--open')
        : document.querySelectorAll('.rexp-row--area.rexp-row--open');
      siblings.forEach(function(s) {
        if (s === row) return;
        collapseRexp(s.dataset.target);
        s.classList.remove('rexp-row--open');
        var a = s.querySelector('.rexp-arrow');
        if (a) a.textContent = '▶';
      });
    }

    function toggleRexp(row) {
      var target = row.dataset.target;
      if (!target) return;
      var arrow  = row.querySelector('.rexp-arrow');
      var isOpen = row.classList.contains('rexp-row--open');
      if (isOpen) {
        collapseRexp(target);
        row.classList.remove('rexp-row--open');
        if (arrow) arrow.textContent = '▶';
      } else {
        collapseSiblings(row);
        document.querySelectorAll('.rexp-child--' + target).forEach(function(c) {
          c.classList.remove('rexp-hidden');
        });
        row.classList.add('rexp-row--open');
        if (arrow) arrow.textContent = '▼';
      }
    }
  </script>
</body>
</html>